		"docs:preview": "pnpm --dir website preview",
		"build": "tsup",
		"test": "vitest run",
		"bench": "vitest bench",
		"bench:baseline": "vitest bench --outputJson benchmarks/vitest-baseline.json",
		"test:watch": "vitest",
