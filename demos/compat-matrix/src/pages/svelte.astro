---
import SvelteDemo from "../components/SvelteDemo.svelte";
import "../styles/demo.css";

const base = import.meta.env.BASE_URL;
const href = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Svelte — GraphReFly Compat Matrix</title>
  </head>
  <body>
    <nav class="demo-nav">
      <a class="nav-brand" href="/">GraphReFly</a>
      <a href={href('/')}>Overview</a>
      <a href={href('/react')}>React</a>
      <a href={href('/vue')}>Vue</a>
      <a href={href('/solid')}>SolidJS</a>
      <a href={href('/svelte')} class="active">Svelte</a>
    </nav>
    <SvelteDemo client:only="svelte" />
  </body>
</html>
