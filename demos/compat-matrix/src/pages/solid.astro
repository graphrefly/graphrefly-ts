---
import SolidDemo from "../components/SolidDemo.tsx";
import "../styles/demo.css";

const base = import.meta.env.BASE_URL;
const href = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SolidJS — GraphReFly Compat Matrix</title>
  </head>
  <body>
    <nav class="demo-nav">
      <a class="nav-brand" href="/">GraphReFly</a>
      <a href={href('/')}>Overview</a>
      <a href={href('/react')}>React</a>
      <a href={href('/vue')}>Vue</a>
      <a href={href('/solid')} class="active">SolidJS</a>
      <a href={href('/svelte')}>Svelte</a>
    </nav>
    <SolidDemo client:only="solid-js" />
  </body>
</html>
