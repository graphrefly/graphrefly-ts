---
import ReactDemo from "../components/ReactDemo.tsx";
import "../styles/demo.css";
import DemoNav from "../../../shared/components/DemoNav.astro";

const base = import.meta.env.BASE_URL;
const href = (p: string) => `${base.replace(/\/$/, "")}/${p.replace(/^\//, "")}`;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>React — GraphReFly Compat Matrix</title>
  </head>
  <body>
    <DemoNav
      links={[
        { href: href("/"), label: "Overview" },
        { href: href("/react"), label: "React", active: true },
        { href: href("/vue"), label: "Vue" },
        { href: href("/solid"), label: "SolidJS" },
        { href: href("/svelte"), label: "Svelte" },
      ]}
    />
    <ReactDemo client:only="react" />
  </body>
</html>
