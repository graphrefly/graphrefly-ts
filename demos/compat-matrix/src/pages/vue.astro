---
import VueDemo from "../components/VueDemo.vue";
import "../styles/demo.css";

const base = import.meta.env.BASE_URL;
const href = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vue — GraphReFly Compat Matrix</title>
  </head>
  <body>
    <nav class="demo-nav">
      <a class="nav-brand" href="/">GraphReFly</a>
      <a href={href('/')}>Overview</a>
      <a href={href('/react')}>React</a>
      <a href={href('/vue')} class="active">Vue</a>
      <a href={href('/solid')}>SolidJS</a>
      <a href={href('/svelte')}>Svelte</a>
    </nav>
    <VueDemo client:only="vue" />
  </body>
</html>
