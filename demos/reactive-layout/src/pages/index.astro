---
import "../styles/layout.css";
import App from "../components/App.tsx";

const base = import.meta.env.BASE_URL;
const href = (p: string) => `${base.replace(/\/$/, "")}/${p.replace(/^\//, "")}`;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reactive layout — GraphReFly</title>
  </head>
  <body>
    <nav class="demo-nav">
      <a class="nav-brand" href="/">GraphReFly</a>
      <a href={href('/')} class="active">Reactive Layout</a>
      <a href="/demos/compat-matrix/">Compat matrix</a>
      <a href="/docs/api/reactivelayout/">API</a>
    </nav>
    <App client:only="react" />
  </body>
</html>
