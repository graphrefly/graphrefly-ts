{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"files": {
		"includes": [
			"**",
			"!dist",
			"!node_modules",
			"!**/dist",
			"!benchmarks",
			"!website",
			"!examples/nestjs-*"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"overrides": [
		{
			"includes": ["demos/compat-matrix/**"],
			"linter": {
				"rules": {
					"a11y": {
						"noStaticElementInteractions": "off",
						"useButtonType": "off",
						"useKeyWithClickEvents": "off"
					},
					"correctness": {
						"noUnusedFunctionParameters": "off",
						"noUnusedImports": "off",
						"noUnusedVariables": "off",
						"useHookAtTopLevel": "off",
						"useJsxKeyInIterable": "off"
					}
				}
			}
		}
	]
}
