{
	"name": "@graphrefly/docs-site",
	"private": true,
	"type": "module",
	"scripts": {
		"sync-docs": "node scripts/sync-docs.mjs",
		"sync-docs:check": "node scripts/sync-docs.mjs --check",
		"docs:gen": "node scripts/gen-api-docs.mjs",
		"docs:gen:check": "node scripts/gen-api-docs.mjs --check",
		"docs:gen:missing": "node scripts/gen-api-docs.mjs --report-missing",
		"build:static-artifact": "pnpm docs:gen && node scripts/build-ts-docs-artifact.mjs",
		"build:starlight-artifact": "pnpm sync-docs && pnpm docs:gen && astro build && node scripts/postbuild-ts-starlight-artifact.mjs",
		"build:ts-artifact": "pnpm build:starlight-artifact",
		"build:legacy": "astro build",
		"predev": "pnpm sync-docs && pnpm docs:gen",
		"prebuild:legacy": "pnpm sync-docs && pnpm docs:gen",
		"dev": "astro dev",
		"start": "astro dev",
		"build": "pnpm build:starlight-artifact",
		"preview": "astro preview"
	},
	"dependencies": {
		"@astrojs/starlight": "^0.37.2",
		"astro": "^5.16.0",
		"sharp": "^0.34.5",
		"starlight-blog": "^0.25.3"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	}
}
