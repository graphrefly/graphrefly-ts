---
/**
 * Splash home (`index.mdx` + GraphreflyHero) ships its own `.gr-footer`.
 * Omit Starlight’s default footer there so only one <footer> appears.
 */
import StarlightFooter from '@astrojs/starlight/components/Footer.astro';

const { starlightRoute } = Astro.locals;
const isSplashHome = starlightRoute.slug === '';
---

{isSplashHome ? null : <StarlightFooter />}
