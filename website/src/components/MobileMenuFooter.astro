---
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const base = import.meta.env.BASE_URL;
const sharedPackages = 'https://graphrefly.dev/packages/';
const navLinks = [
	{ href: `${base}api/`, label: 'API' },
	{ href: `${base}solutions/`, label: 'SOLUTIONS' },
	{ href: `${base}examples/`, label: 'EXAMPLES' },
	{ href: `${base}demos/`, label: 'DEMOS' },
	{ href: `${base}recipes/`, label: 'RECIPES' },
	{ href: `${base}integrations/`, label: 'INTEGRATIONS' },
	{ href: `${base}compare/`, label: 'COMPARE' },
	{ href: sharedPackages, label: 'PACKAGES' },
];
---

<nav class="gr-mobile-nav" aria-label="Quick links">
	{navLinks.map(({ href, label }) => (
		<a href={href} class="gr-mobile-nav-link">{label}</a>
	))}
</nav>
<div class="mobile-preferences sl-flex">
	<div class="social-icons">
		<SocialIcons />
	</div>
	<ThemeSelect />
	<LanguageSelect />
</div>

<style>
	@layer starlight.core {
		.gr-mobile-nav {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			padding: 0.75rem 0;
			border-top: 1px solid var(--sl-color-gray-6);
		}
		.gr-mobile-nav-link {
			font-size: var(--sl-text-xs);
			font-weight: 700;
			letter-spacing: 0.1em;
			text-decoration: none;
			color: var(--sl-color-gray-2);
			padding: 0.4em 0.6em;
			border-radius: 0.375rem;
			border: 1px solid var(--sl-color-gray-5);
		}
		.gr-mobile-nav-link:hover {
			color: var(--sl-color-text-accent);
			border-color: var(--sl-color-text-accent);
		}
		.social-icons {
			display: flex;
			margin-inline-end: auto;
			gap: 1rem;
			align-items: center;
			padding-block: 1rem;
		}
		.social-icons:empty {
			display: none;
		}
		.mobile-preferences {
			justify-content: space-between;
			flex-wrap: wrap;
			border-top: 1px solid var(--sl-color-gray-6);
			column-gap: 1rem;
			padding: 0.5rem 0;
		}
	}
</style>
