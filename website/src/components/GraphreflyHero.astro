---
const base = import.meta.env.BASE_URL;
---

<div class="gr-home">
	<!-- ══ HERO ══ -->
	<section class="gr-hero">
		<div class="gr-hero-bg" aria-hidden="true"></div>
		<div class="gr-orb gr-orb-1" aria-hidden="true"></div>
		<div class="gr-orb gr-orb-2" aria-hidden="true"></div>
		<div class="gr-orb gr-orb-3" aria-hidden="true"></div>

		<div class="gr-flow-lines" aria-hidden="true">
			<svg viewBox="0 0 1440 900" preserveAspectRatio="none">
				<defs>
					<linearGradient id="gr-prismGrad1" x1="0%" y1="0%" x2="100%" y2="0%">
						<stop offset="0%" stop-color="#4de8c2" />
						<stop offset="50%" stop-color="#a78bfa" />
						<stop offset="100%" stop-color="#f472b6" />
					</linearGradient>
					<linearGradient id="gr-prismGrad2" x1="0%" y1="0%" x2="100%" y2="0%">
						<stop offset="0%" stop-color="#f472b6" />
						<stop offset="50%" stop-color="#f0a858" />
						<stop offset="100%" stop-color="#4de8c2" />
					</linearGradient>
					<linearGradient id="gr-prismGrad3" x1="0%" y1="0%" x2="100%" y2="0%">
						<stop offset="0%" stop-color="#a78bfa" />
						<stop offset="50%" stop-color="#4de8c2" />
						<stop offset="100%" stop-color="#f0a858" />
					</linearGradient>
				</defs>
				<path class="gr-flow-line gr-fl-1" d="M-50 300 C300 280, 500 450, 800 350 S1200 250, 1500 380" stroke="url(#gr-prismGrad1)" />
				<path class="gr-flow-line gr-fl-2" d="M-50 500 C200 480, 450 350, 720 480 S1100 550, 1500 450" stroke="url(#gr-prismGrad2)" />
				<path class="gr-flow-line gr-fl-3" d="M-50 700 C350 680, 600 550, 900 650 S1250 700, 1500 600" stroke="url(#gr-prismGrad3)" />
			</svg>
		</div>

		<div class="gr-hero-inner">
			<div class="gr-kicker">Reactive Graph Protocol</div>
			<h1 class="gr-title">Graph<span class="gr-title-re">Re</span>Fly.</h1>
			<p class="gr-tagline">Human + LLM co-operation on a shared, inspectable graph.</p>
			<div class="gr-hero-buttons">
				<div class="gr-hero-row gr-hero-row--install">
					<div class="gr-install-box">
						<code class="gr-install-cmd" translate="no">npm i @graphrefly/graphrefly</code>
						<button type="button" class="gr-install-copy" aria-label="Copy install command">
							<span class="gr-install-copy-label">Copy</span>
						</button>
					</div>
					<a
						class="gr-btn gr-btn-ghost gr-hero-gh"
						href="https://github.com/graphrefly/graphrefly-ts"
						target="_blank"
						rel="noopener noreferrer">graphrefly-ts</a>
				</div>
				<div class="gr-hero-row gr-hero-row--cta">
					<a class="gr-btn gr-btn-primary" href={`${base}spec/`}>Read the Spec</a>
					<a class="gr-btn gr-btn-ghost" href="#implementations">More Implementations</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ══ FEATURES ══ -->
	<section class="gr-features-section">
		<div class="gr-container">
			<div class="gr-section-kicker">Core Concepts</div>
			<h2 class="gr-section-title">Built on first principles.</h2>

			<div class="gr-features-grid">
				<div class="gr-feature-card gr-fc-amber" data-reveal>
					<div class="gr-feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M3 12h1m16 0h1M12 3v1m0 16v1M18.364 5.636l-.707.707m-11.314 0l.707.707m11.314 11.314l-.707-.707m-11.314 0l.707-.707"/></svg>
					</div>
					<h3>Reactive Precision</h3>
					<p>Combining <strong>Callbag-ish</strong> minimalism with <strong>Diamond-safe</strong> correctness. A protocol small enough for an LLM to reason about, yet robust enough to eliminate race conditions through a rigorous <strong>two-phase push</strong> mechanism (<strong>DIRTY</strong> then <strong>DATA</strong>). Every flow is glitch-free, high-performance, and mathematically sound.</p>
				</div>
				<div class="gr-feature-card gr-fc-aqua" data-reveal>
					<div class="gr-feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
					</div>
					<h3>Governed Integrity</h3>
					<p>Trust is not an add-on; it is the protocol. With <strong>ABAC</strong> (Attribute-Based Access Control) and <strong>Versioning</strong> baked directly into both nodes and graphs, every state change is authorized, immutable, and auditable. Complex reactive systems remain stable, secure, and effortlessly reversible.</p>
				</div>
				<div class="gr-feature-card gr-fc-purple" data-reveal>
					<div class="gr-feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
					</div>
					<h3>Living Blueprints</h3>
					<p>Moving from ephemeral code to <strong>Introspectable Artifacts</strong>. Graphs are modular, pluggable solutions that encapsulate <strong>Values, Status, and Algorithm</strong> into a single, serializable unit. Through the <strong>Companion Store</strong>, every step is accountable and every metadata point is inspectable.</p>
				</div>
				<div class="gr-feature-card gr-fc-pink" data-reveal>
					<div class="gr-feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>
					</div>
					<h3>Agentic Co-operation</h3>
					<p>A symbiotic workspace where <strong>Humans master the abstraction</strong> and <strong>AI masters the implementation</strong>. By unifying security, observability, and composability, GraphReFly provides the perfect arena for agents&mdash;human or LLM&mdash;to play to their strengths and rely on a shared, transparent logic.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ══ PRISM ══ -->
	<section class="gr-prism-section" id="gr-prism-section">
		<div class="gr-container">
			<div class="gr-prism-visual">
				<svg viewBox="0 0 700 320" fill="none">
					<path class="gr-prism-beam-in" d="M 0 160 L 280 160" stroke="rgba(255,255,255,0.7)" stroke-width="2" />
					<polygon class="gr-prism-shape" points="310,80 400,160 310,240 220,160" />
					<path class="gr-prism-beam-out" d="M 400 160 L 700 60" stroke="#4de8c2" stroke-width="2" />
					<path class="gr-prism-beam-out" d="M 400 160 L 700 110" stroke="#7dd3fc" stroke-width="2" />
					<path class="gr-prism-beam-out" d="M 400 160 L 700 160" stroke="#a78bfa" stroke-width="2" />
					<path class="gr-prism-beam-out" d="M 400 160 L 700 210" stroke="#f472b6" stroke-width="2" />
					<path class="gr-prism-beam-out" d="M 400 160 L 700 260" stroke="#f0a858" stroke-width="2" />
					<circle cx="310" cy="160" r="60" fill="url(#gr-prismCenter)" opacity="0.3" />
					<defs>
						<radialGradient id="gr-prismCenter">
							<stop offset="0%" stop-color="white" stop-opacity="0.5" />
							<stop offset="100%" stop-color="white" stop-opacity="0" />
						</radialGradient>
					</defs>
				</svg>
			</div>
			<h2 class="gr-prism-title">One protocol. <span>Every spectrum.</span></h2>
			<p class="gr-section-sub">A single message format &mdash; tuples of [Type, Data?] &mdash; powers sources, sinks, operators, and entire graphs. The same primitive adapts to every use case, from real-time UI bindings to LLM agentic memory.</p>
		</div>
	</section>

	<!-- ══ CODE ══ -->
	<section class="gr-code-section">
		<div class="gr-container" style="text-align: center;">
			<div class="gr-section-kicker">Developer Experience</div>
			<h2 class="gr-section-title">Clean, expressive, typed.</h2>
			<p class="gr-section-sub" style="margin: 0 auto;">Sugar constructors keep the common path simple. The protocol stays accessible underneath.</p>

			<div class="gr-code-card">
				<div class="gr-code-card-header"></div>
				<div class="gr-code-card-top">
					<div class="gr-code-dot" aria-hidden="true"></div>
					<div class="gr-code-dot" aria-hidden="true"></div>
					<div class="gr-code-dot" aria-hidden="true"></div>
					<span>graph.ts</span>
				</div>
				<div class="gr-code-body">
<pre><span class="kw">const</span> <span class="pr">count</span>   <span class="op">=</span> <span class="fn">state</span><span class="br">(</span><span class="num">0</span><span class="br">)</span><span class="op">;</span>
<span class="kw">const</span> <span class="pr">doubled</span> <span class="op">=</span> <span class="fn">derived</span><span class="br">(</span><span class="br">[</span><span class="pr">count</span><span class="br">]</span><span class="op">,</span> <span class="br">(</span><span class="pr">c</span><span class="br">)</span> <span class="op">=&gt;</span> <span class="pr">c</span> <span class="op">*</span> <span class="num">2</span><span class="br">)</span><span class="op">;</span>

<span class="fn">effect</span><span class="br">(</span><span class="br">[</span><span class="pr">doubled</span><span class="br">]</span><span class="op">,</span> <span class="br">(</span><span class="pr">d</span><span class="br">)</span> <span class="op">=&gt;</span> <span class="pr">console</span><span class="op">.</span><span class="fn">log</span><span class="br">(</span><span class="pr">d</span><span class="br">)</span><span class="br">)</span><span class="op">;</span>

<span class="pr">count</span><span class="op">.</span><span class="fn">down</span><span class="br">(</span><span class="br">[</span><span class="br">[</span><span class="type">DATA</span><span class="op">,</span> <span class="num">1</span><span class="br">]</span><span class="br">]</span><span class="br">)</span><span class="op">;</span>  <span class="cm">// logs: 2</span></pre>
				</div>
			</div>
		</div>
	</section>

	<!-- ══ USE CASES ══ -->
	<section class="gr-usecases-section">
		<div class="gr-container" style="text-align: center;">
			<div class="gr-section-kicker">Use Cases</div>
			<h2 class="gr-section-title">One graph, many domains.</h2>
			<p class="gr-section-sub" style="margin: 0 auto;">The protocol is domain-agnostic. The graph carries whatever your system needs.</p>

			<div class="gr-usecases-grid">
				<div class="gr-usecase-card" data-reveal>
					<span class="gr-usecase-icon">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
					</span>
					<h4>Orchestration</h4>
					<p>Coordinate multi-step workflows with observable state at every node.</p>
				</div>
				<div class="gr-usecase-card" data-reveal>
					<span class="gr-usecase-icon">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3 4 7l4 4"/><path d="M4 7h16"/><path d="m16 21 4-4-4-4"/><path d="M20 17H4"/></svg>
					</span>
					<h4>Message Queue</h4>
					<p>Reactive pub/sub with backpressure, built on the same tuple protocol.</p>
				</div>
				<div class="gr-usecase-card" data-reveal>
					<span class="gr-usecase-icon">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
					</span>
					<h4>AI Agentic Memory</h4>
					<p>LLMs read and write graph nodes as persistent, inspectable memory.</p>
				</div>
				<div class="gr-usecase-card" data-reveal>
					<span class="gr-usecase-icon">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="M12 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/><path d="M12 11v3"/></svg>
					</span>
					<h4>Security</h4>
					<p>Audit trails and permission boundaries at the protocol level.</p>
				</div>
				<div class="gr-usecase-card" data-reveal>
					<span class="gr-usecase-icon">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>
					</span>
					<h4>Human + AI Ops</h4>
					<p>Shared graphs where humans observe, approve, and intervene in real time.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ══ IMPLEMENTATIONS ══ -->
	<section class="gr-impl-section" id="implementations">
		<div class="gr-container">
			<div class="gr-section-kicker">Implementations</div>
			<h2 class="gr-section-title" style="text-align: center;">One light, two prisms.</h2>
			<p class="gr-section-sub" style="margin: 0 auto; text-align: center;">Same protocol, native implementations. Use whichever fits your stack.</p>

			<div class="gr-impl-grid">
				<div class="gr-impl-card gr-impl-ts">
					<span class="gr-impl-icon" style="color: var(--gr-aqua);">TS</span>
					<h3>TypeScript</h3>
					<p>First-class types, tree-shakeable, zero dependencies. Works everywhere JS runs.</p>
					<a href="https://github.com/graphrefly/graphrefly-ts" class="gr-btn gr-btn-ghost gr-impl-gh-btn" target="_blank" rel="noopener noreferrer">View on Github</a>
					<button
						type="button"
						class="gr-btn gr-btn-ghost gr-impl-btn gr-impl-cmd gr-impl-cmd--ts"
						data-copy-text="npm i @graphrefly/graphrefly"
						data-default-label="npm i @graphrefly/graphrefly"
						aria-label="Copy TypeScript install command">npm i @graphrefly/graphrefly</button>
				</div>

				<div class="gr-impl-connector">
					<div class="gr-impl-line"></div>
					<span>SAME SPEC</span>
					<div class="gr-impl-line"></div>
				</div>

				<div class="gr-impl-card gr-impl-py">
					<span class="gr-impl-icon" style="color: var(--gr-amber);">PY</span>
					<h3>Python</h3>
					<p>Async-native, type-hinted, built for data pipelines and LLM agent frameworks.</p>
					<a href="https://github.com/graphrefly/graphrefly-py" class="gr-btn gr-btn-ghost gr-impl-gh-btn gr-impl-gh-btn--py" target="_blank" rel="noopener noreferrer">View on Github</a>
					<button
						type="button"
						class="gr-btn gr-btn-ghost gr-impl-btn gr-impl-btn--py gr-impl-cmd gr-impl-cmd--py"
						data-copy-text="pip install graphrefly"
						data-default-label="pip install graphrefly"
						aria-label="Copy Python install command">pip install graphrefly</button>
				</div>
			</div>
		</div>
	</section>
</div>

<style is:global>
	/* ── GraphReFly Home — E-glass-light ── */

	/* Break out of Starlight's content wrapper */
	.sl-markdown-content:has(.gr-home) {
		max-width: 100% !important;
	}
	.content-panel:has(.gr-home) {
		max-width: 100% !important;
		padding: 0 !important;
	}
	.content-panel:has(.gr-home) .sl-container {
		max-width: 100% !important;
		padding: 0 !important;
	}
	/* Hide the default Starlight page title */
	.content-panel:has(.gr-home) .hero {
		display: none;
	}

	.gr-home {
		--gr-aqua: #4de8c2;
		--gr-aqua-dim: #2bb89a;
		--gr-purple: #a78bfa;
		--gr-pink: #f472b6;
		--gr-amber: #f0a858;
		--gr-glass-bg: rgba(255,255,255,0.04);
		--gr-glass-bg-hover: rgba(255,255,255,0.09);
		--gr-glass-border: rgba(255,255,255,0.08);
		--gr-glass-border-hover: rgba(255,255,255,0.18);
		--gr-text: #f0f4ff;
		--gr-muted: #8899b0;
		--gr-bg-start: #0a0a1a;
		--gr-bg-mid: #0d1525;
		--gr-bg-end: #0a1628;
		color: var(--gr-text);
		font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
		max-width: none;
		width: 100%;
	}

	/* ── HERO ── */
	.gr-hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 72px 24px 80px;
		overflow: hidden;
	}

	.gr-hero-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 80% 60% at 20% 40%, rgba(77,232,194,0.12) 0%, transparent 60%),
			radial-gradient(ellipse 60% 50% at 75% 30%, rgba(167,139,250,0.1) 0%, transparent 55%),
			radial-gradient(ellipse 50% 40% at 50% 70%, rgba(244,114,182,0.08) 0%, transparent 50%),
			radial-gradient(ellipse 40% 30% at 80% 80%, rgba(240,168,88,0.07) 0%, transparent 50%),
			linear-gradient(180deg, var(--gr-bg-start) 0%, var(--gr-bg-mid) 50%, var(--gr-bg-end) 100%);
		z-index: 0;
	}

	.gr-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		z-index: 1;
		will-change: transform;
	}

	.gr-orb-1 {
		width: 500px; height: 500px;
		background: radial-gradient(circle, rgba(77,232,194,0.35), rgba(167,139,250,0.2), transparent);
		top: 10%; left: 5%;
		animation: gr-float1 28s ease-in-out infinite;
	}
	.gr-orb-2 {
		width: 400px; height: 400px;
		background: radial-gradient(circle, rgba(244,114,182,0.3), rgba(167,139,250,0.15), transparent);
		top: 30%; right: 5%;
		animation: gr-float2 25s ease-in-out infinite;
	}
	.gr-orb-3 {
		width: 350px; height: 350px;
		background: radial-gradient(circle, rgba(240,168,88,0.25), rgba(244,114,182,0.15), transparent);
		bottom: 10%; left: 30%;
		animation: gr-float3 30s ease-in-out infinite;
	}

	@keyframes gr-float1 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		25% { transform: translate(60px, -40px) scale(1.05); }
		50% { transform: translate(-30px, 50px) scale(0.95); }
		75% { transform: translate(40px, 20px) scale(1.02); }
	}
	@keyframes gr-float2 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		33% { transform: translate(-50px, 30px) scale(1.08); }
		66% { transform: translate(30px, -50px) scale(0.96); }
	}
	@keyframes gr-float3 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		20% { transform: translate(40px, -30px) scale(1.04); }
		50% { transform: translate(-60px, -20px) scale(0.97); }
		80% { transform: translate(20px, 40px) scale(1.06); }
	}

	/* SVG flow lines */
	.gr-flow-lines {
		position: absolute;
		inset: 0;
		z-index: 2;
		pointer-events: none;
	}
	.gr-flow-lines svg { width: 100%; height: 100%; }
	.gr-flow-line {
		fill: none;
		stroke-width: 1.5;
		stroke-linecap: round;
		opacity: 0.4;
		stroke-dasharray: 1200;
		stroke-dashoffset: 1200;
		animation: gr-drawLine 4s ease-out forwards;
	}
	/* Line 1 leads from the left; line 2 carries amber — delay it to match the lower “right” group */
	.gr-fl-1 { animation-delay: 0.3s; }
	.gr-fl-2 { animation-delay: 1.2s; }
	.gr-fl-3 { animation-delay: 1.35s; }
	@keyframes gr-drawLine { to { stroke-dashoffset: 0; } }

	/* Hero content */
	.gr-hero-inner {
		position: relative;
		z-index: 10;
		max-width: 800px;
		padding: 0 0.5rem;
	}

	.gr-kicker {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 20px;
		border-radius: 999px;
		background: rgba(255,255,255,0.06);
		border: 1px solid rgba(255,255,255,0.08);
		backdrop-filter: blur(12px);
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--gr-muted);
		margin-bottom: 32px;
	}
	.gr-kicker::before {
		content: '';
		width: 6px; height: 6px;
		border-radius: 50%;
		background: var(--gr-aqua);
		box-shadow: 0 0 8px var(--gr-aqua);
	}

	.gr-title {
		font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
		font-size: clamp(3rem, 8vw, 6rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.05;
		margin: 0 0 24px;
		color: var(--gr-text);
	}
	.gr-title-re {
		background: linear-gradient(90deg, var(--gr-aqua), var(--gr-purple), var(--gr-pink), var(--gr-amber), var(--gr-aqua));
		background-size: 300% 100%;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: gr-prismaticShift 8s ease-in-out infinite;
	}
	@keyframes gr-prismaticShift {
		0%, 100% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
	}

	.gr-tagline {
		font-size: clamp(1.1rem, 2.5vw, 1.35rem);
		font-weight: 300;
		color: var(--gr-muted);
		line-height: 1.6;
		margin-bottom: 48px;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.gr-hero-buttons {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 20px;
		width: 100%;
		max-width: 520px;
		margin-inline: auto;
	}
	.gr-hero-row {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		justify-content: center;
		align-items: stretch;
		width: 100%;
	}
	.gr-hero-row--install {
		align-items: stretch;
	}
	.gr-hero-row--cta {
		align-items: center;
	}
	.gr-install-box {
		display: flex;
		align-items: stretch;
		flex: 1 1 12rem;
		min-width: 0;
		max-width: 22rem;
		border-radius: 12px;
		background: rgba(0, 0, 0, 0.35);
		border: 1px solid rgba(255, 255, 255, 0.1);
		overflow: hidden;
	}
	.gr-install-box .gr-install-cmd {
		display: block;
		flex: 1;
		margin: 0;
		padding: 12px 14px;
		border: none;
		background: transparent;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--gr-text);
		letter-spacing: 0.02em;
		text-align: start;
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.gr-install-copy {
		flex: 0 0 6.5rem;
		width: 6.5rem;
		min-width: 6.5rem;
		padding: 0 8px;
		border: none;
		border-left: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.06);
		color: var(--gr-muted);
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		cursor: pointer;
		font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
		transition: background 0.2s ease, color 0.2s ease;
	}
	.gr-install-copy:hover,
	.gr-install-copy:focus-visible {
		color: var(--gr-text);
		background: rgba(255, 255, 255, 0.1);
		outline: none;
	}
	.gr-hero-gh {
		flex: 0 0 auto;
		min-width: 10rem;
		justify-content: center;
	}

	/* ── BUTTONS ── */
	.gr-btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 14px 32px;
		border-radius: 14px;
		font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		cursor: pointer;
		border: none;
		transition: all 0.3s ease;
		position: relative;
	}

	.gr-btn-primary {
		background: rgba(255,255,255,0.06);
		color: var(--gr-text);
		border: 1px solid transparent;
		background-clip: padding-box;
		isolation: isolate;
	}
	.gr-btn-primary::before {
		content: '';
		position: absolute;
		inset: -1px;
		border-radius: 15px;
		background: linear-gradient(135deg, var(--gr-aqua), var(--gr-purple), var(--gr-pink));
		z-index: -2;
	}
	.gr-btn-primary::after {
		content: '';
		position: absolute;
		inset: 1px;
		border-radius: 13px;
		background: rgba(10,10,26,0.85);
		backdrop-filter: blur(12px);
		z-index: -1;
		transition: background 0.3s;
	}
	.gr-btn-primary:hover::after {
		background: rgba(10,10,26,0.7);
	}
	.gr-btn-primary:hover {
		color: var(--gr-text);
	}

	.gr-btn-ghost {
		background: rgba(255,255,255,0.05);
		border: 1px solid rgba(255,255,255,0.1);
		color: var(--gr-muted);
		backdrop-filter: blur(12px);
	}
	.gr-btn-ghost:hover {
		background: rgba(255,255,255,0.09);
		color: var(--gr-text);
		border-color: rgba(255,255,255,0.18);
	}

	/* ── SECTIONS COMMON ── */
	.gr-home section {
		position: relative;
		padding: 120px 24px;
	}
	.gr-container {
		max-width: 1120px;
		margin: 0 auto;
	}
	.gr-section-kicker {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--gr-muted);
		margin-top: 0 !important;
		margin-bottom: 8px !important;
		text-align: center;
	}
	.gr-section-title {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.15;
		margin-top: 0 !important;
		margin-bottom: 12px !important;
		color: var(--gr-text);
		text-align: center;
	}
	.gr-section-sub {
		font-size: 1.05rem;
		font-weight: 300;
		color: var(--gr-muted);
		line-height: 1.7;
		max-width: 560px;
	}

	/* ── FEATURES ── */
	.gr-features-section {
		background: transparent;
	}
	.gr-features-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 24px;
		margin-top: 64px;
		/* Top-align both columns; avoids any cross-axis centering that drops column 2 */
		align-items: start;
		justify-items: stretch;
	}
	/* Prose/stack margins on MDX siblings can offset column 2 — reset */
	.gr-features-grid > * {
		margin-block: 0;
	}
	.gr-feature-card {
		position: relative;
		display: flex;
		flex-direction: column;
		height: 100%;
		min-height: 0;
		padding: 40px 36px;
		border-radius: 24px;
		background: var(--gr-glass-bg);
		border: 1px solid var(--gr-glass-border);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		overflow: hidden;
		transition: all 0.3s ease;
		opacity: 0;
		transform: translateY(20px);
		box-sizing: border-box;
	}
	.gr-feature-card.visible {
		opacity: 1;
		transform: translateY(0);
	}
	.gr-feature-card:hover {
		background: var(--gr-glass-bg-hover);
		border-color: var(--gr-glass-border-hover);
		transform: translateY(-4px);
	}
	.gr-feature-card.visible:hover {
		transform: translateY(-4px);
	}
	.gr-feature-card::before {
		content: '';
		position: absolute;
		top: -40px; left: -40px;
		width: 120px; height: 120px;
		border-radius: 50%;
		filter: blur(50px);
		opacity: 0.5;
		transition: opacity 0.3s;
	}
	.gr-feature-card:hover::before { opacity: 0.75; }
	.gr-fc-amber::before { background: var(--gr-amber); }
	.gr-fc-aqua::before { background: var(--gr-aqua); }
	.gr-fc-purple::before { background: var(--gr-purple); }
	.gr-fc-pink::before { background: var(--gr-pink); }

	.gr-feature-icon {
		width: 48px; height: 48px;
		border-radius: 14px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 24px;
		background: rgba(255,255,255,0.06);
		border: 1px solid rgba(255,255,255,0.08);
		font-size: 1.3rem;
	}
	.gr-feature-card h3 {
		font-size: 1.2rem;
		font-weight: 700;
		margin: 0 0 12px;
		letter-spacing: -0.01em;
		color: var(--gr-text);
	}
	.gr-feature-card p {
		font-size: 0.95rem;
		font-weight: 300;
		color: var(--gr-muted);
		margin: 0;
		line-height: 1.65;
		flex: 1 1 auto;
	}
	.gr-feature-card p strong {
		color: var(--gr-text);
		font-weight: 500;
	}

	/* ── PRISM SECTION ── */
	.gr-prism-section {
		text-align: center;
		overflow: hidden;
	}
	.gr-prism-visual {
		position: relative;
		width: 100%;
		max-width: 700px;
		height: 320px;
		margin: 0 auto 48px;
	}
	.gr-prism-visual svg { width: 100%; height: 100%; }
	.gr-prism-beam-in {
		fill: none;
		stroke-dasharray: 400;
		stroke-dashoffset: 400;
	}
	.gr-prism-beam-out {
		stroke-width: 2;
		fill: none;
		stroke-dasharray: 400;
		stroke-dashoffset: 400;
	}
	.gr-prism-section.visible .gr-prism-beam-in {
		animation: gr-drawBeam 1.5s ease-out forwards;
	}
	.gr-prism-section.visible .gr-prism-beam-out {
		animation: gr-drawBeam 1.5s ease-out forwards;
	}
	/* svg children: beam-in, polygon, then five gr-prism-beam-out (last is amber) */
	.gr-prism-section.visible .gr-prism-beam-out:nth-child(3) { animation-delay: 1.0s; }
	.gr-prism-section.visible .gr-prism-beam-out:nth-child(4) { animation-delay: 1.2s; }
	.gr-prism-section.visible .gr-prism-beam-out:nth-child(5) { animation-delay: 1.4s; }
	.gr-prism-section.visible .gr-prism-beam-out:nth-child(6) { animation-delay: 1.6s; }
	/* 7th child: yellow beam — was missing, so it fired at t=0; align with other outward beams */
	.gr-prism-section.visible .gr-prism-beam-out:nth-child(7) { animation-delay: 1.6s; }
	@keyframes gr-drawBeam { to { stroke-dashoffset: 0; } }
	.gr-prism-shape {
		fill: rgba(255,255,255,0.04);
		stroke: rgba(255,255,255,0.15);
		stroke-width: 1.5;
	}
	.gr-prism-title {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-top: 0 !important;
		margin-bottom: 12px !important;
		color: var(--gr-text);
	}
	.gr-prism-title span {
		background: linear-gradient(90deg, var(--gr-aqua), var(--gr-purple), var(--gr-pink), var(--gr-amber));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.gr-prism-section .gr-section-sub {
		margin: 0 auto;
		text-align: center;
	}

	/* ── CODE SECTION ── */
	.gr-code-section {
		background:
			radial-gradient(ellipse 50% 40% at 50% 50%, rgba(167,139,250,0.06) 0%, transparent 70%);
	}
	/* Code pane — matches website/prototypes/E-glass-light.html */
	.gr-code-card {
		max-width: 720px;
		margin: 48px auto 0;
		border-radius: 20px;
		overflow: hidden;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		backdrop-filter: blur(16px);
	}
	.gr-code-card-header {
		height: 3px;
		background: linear-gradient(90deg, var(--gr-aqua), var(--gr-purple), var(--gr-pink));
	}
	.gr-code-card-top {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 10px 16px;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.gr-code-dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		flex-shrink: 0;
		margin-top: 0 !important;
		margin-bottom: 0 !important;
	}
	.gr-code-card-top .gr-code-dot:nth-child(1) { background: #ff5f56; }
	.gr-code-card-top .gr-code-dot:nth-child(2) { background: #ffbd2e; }
	.gr-code-card-top .gr-code-dot:nth-child(3) { background: #27c93f; }
	.gr-code-card-top span {
		margin-left: auto;
		font-size: 0.75rem;
		color: var(--gr-muted);
		font-family: 'Fira Code', monospace;
		margin-top: 0 !important;
		margin-bottom: 0 !important;
	}
	.gr-code-body {
		padding: 28px 28px;
		background: rgba(6, 6, 18, 0.6);
		display: flex;
		justify-content: center;
		margin-top: 0 !important;
	}
	.gr-code-body pre {
		margin: 0;
		font-family: 'Fira Code', monospace;
		font-size: 0.875rem;
		line-height: 1.8;
		overflow-x: auto;
		text-align: left;
		max-width: 520px;
		width: 100%;
		padding: 0;
		background: transparent;
		border: none;
		box-shadow: none;
	}
	.gr-code-body .kw { color: var(--gr-purple); }
	.gr-code-body .fn { color: var(--gr-aqua); }
	.gr-code-body .str { color: var(--gr-pink); }
	.gr-code-body .num { color: var(--gr-amber); }
	.gr-code-body .cm { color: #5a6a80; font-style: italic; }
	.gr-code-body .br { color: rgba(255,255,255,0.35); }
	.gr-code-body .op { color: rgba(255,255,255,0.5); }
	.gr-code-body .pr { color: var(--gr-text); }
	.gr-code-body .type { color: #7dd3fc; }

	/* ── USE CASES ── */
	.gr-usecases-grid {
		display: flex;
		gap: 20px;
		margin-top: 64px;
		flex-wrap: wrap;
		justify-content: center;
	}
	.gr-usecase-card {
		flex: 1 1 200px;
		max-width: 220px;
		padding: 32px 24px;
		border-radius: 20px;
		background: var(--gr-glass-bg);
		border: 1px solid var(--gr-glass-border);
		backdrop-filter: blur(12px);
		text-align: center;
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
		opacity: 0;
		transform: translateY(20px);
	}
	.gr-usecase-card.visible {
		opacity: 1;
		transform: translateY(0);
	}
	.gr-usecase-card:nth-child(even) { transform: translateY(16px); }
	.gr-usecase-card:nth-child(even).visible { transform: translateY(16px); }
	.gr-usecase-card:hover {
		background: var(--gr-glass-bg-hover);
		transform: translateY(-4px);
	}
	.gr-usecase-card:nth-child(even):hover { transform: translateY(12px); }
	.gr-usecase-card::after {
		content: '';
		position: absolute;
		inset: -1px;
		border-radius: 20px;
		background: linear-gradient(135deg, transparent 40%, var(--gr-aqua), var(--gr-purple), transparent 80%);
		opacity: 0;
		z-index: -1;
		transition: opacity 0.3s;
	}
	.gr-usecase-card:hover::after { opacity: 0.15; }
	.gr-usecase-icon {
		font-size: 1.6rem;
		margin-bottom: 16px;
		display: block;
	}
	.gr-usecase-card h4 {
		font-size: 0.95rem;
		font-weight: 600;
		margin: 0 0 8px;
		color: var(--gr-text);
	}
	.gr-usecase-card p {
		font-size: 0.8rem;
		color: var(--gr-muted);
		font-weight: 300;
		line-height: 1.5;
		margin: 0;
	}
	.gr-usecase-card:nth-child(1) .gr-usecase-icon { color: var(--gr-aqua); }
	.gr-usecase-card:nth-child(2) .gr-usecase-icon { color: var(--gr-purple); }
	.gr-usecase-card:nth-child(3) .gr-usecase-icon { color: var(--gr-pink); }
	.gr-usecase-card:nth-child(4) .gr-usecase-icon { color: var(--gr-amber); }
	.gr-usecase-card:nth-child(5) .gr-usecase-icon { color: var(--gr-aqua); }

	/* ── IMPLEMENTATIONS ── */
	.gr-impl-section { text-align: center; }
	.gr-impl-grid {
		display: grid;
		grid-template-columns: minmax(260px, 1fr) auto minmax(260px, 1fr);
		gap: 32px;
		align-items: start;
		justify-content: center;
		margin-top: 56px;
		max-width: 960px;
		margin-left: auto;
		margin-right: auto;
	}
	.gr-impl-grid > * {
		margin-block: 0;
	}
	.gr-impl-card {
		width: 100%;
		max-width: 400px;
		margin: 0 auto;
		padding: 48px 36px;
		border-radius: 24px;
		background: var(--gr-glass-bg);
		border: 1px solid var(--gr-glass-border);
		backdrop-filter: blur(16px);
		text-align: center;
		position: relative;
		overflow: hidden;
		transition: all 0.3s;
		display: flex;
		flex-direction: column;
		align-items: center;
		box-sizing: border-box;
	}
	.gr-impl-card:hover {
		background: var(--gr-glass-bg-hover);
		border-color: var(--gr-glass-border-hover);
		transform: translateY(-4px);
	}
	.gr-impl-card::before {
		content: '';
		position: absolute;
		top: -1px;
		left: 20%; right: 20%;
		height: 2px;
		border-radius: 2px;
	}
	.gr-impl-ts::before { background: linear-gradient(90deg, transparent, var(--gr-aqua), transparent); }
	.gr-impl-py::before { background: linear-gradient(90deg, transparent, var(--gr-amber), transparent); }
	.gr-impl-icon {
		font-size: 2.4rem;
		margin-bottom: 20px;
		display: block;
	}
	.gr-impl-card h3 {
		font-size: 1.3rem;
		font-weight: 700;
		margin: 0 0 8px;
		color: var(--gr-text);
	}
	.gr-impl-card p {
		font-size: 0.9rem;
		color: var(--gr-muted);
		font-weight: 300;
		margin: 0 0 16px;
	}
	.gr-impl-gh-btn {
		font-size: 0.85rem !important;
		padding: 10px 24px !important;
		margin: 0 0 12px;
		width: 100%;
		max-width: 280px;
		justify-content: center;
	}
	.gr-impl-gh-btn--py {
		border-color: rgba(240, 168, 88, 0.25);
		color: var(--gr-amber);
	}
	.gr-impl-gh-btn--py:hover {
		color: #f5c47a;
		border-color: rgba(240, 168, 88, 0.4);
	}
	.gr-impl-btn {
		font-size: 0.85rem !important;
		padding: 10px 24px !important;
		width: 100%;
		max-width: 280px;
		justify-content: center;
	}
	.gr-impl-btn--py {
		color: var(--gr-amber);
		border-color: rgba(240, 168, 88, 0.25);
	}
	.gr-impl-btn--py:hover {
		color: #f5c47a;
		border-color: rgba(240, 168, 88, 0.4);
	}
	.gr-impl-cmd {
		font-family: ui-monospace, 'JetBrains Mono', 'SF Mono', monospace;
		font-size: 0.78rem !important;
		font-weight: 500;
		letter-spacing: 0.02em;
	}
	.gr-impl-cmd--ts {
		color: var(--gr-aqua);
		border-color: rgba(77, 232, 194, 0.25);
	}
	.gr-impl-cmd--ts:hover {
		color: #6ef0d4;
		border-color: rgba(77, 232, 194, 0.4);
		background: rgba(77, 232, 194, 0.06);
	}
	.gr-impl-cmd--py {
		border-color: rgba(240, 168, 88, 0.28);
	}
	.gr-impl-cmd--py:hover {
		border-color: rgba(240, 168, 88, 0.45);
		background: rgba(240, 168, 88, 0.06);
	}
	.gr-impl-connector {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
		color: var(--gr-muted);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		/* Center the bridge in the row while cards use align-items: start */
		align-self: center;
		justify-self: center;
	}
	.gr-impl-line {
		width: 2px; height: 40px;
		background: linear-gradient(180deg, var(--gr-aqua), var(--gr-purple), var(--gr-pink), var(--gr-amber));
		border-radius: 2px;
	}

	/* ── RESPONSIVE ── */
	@media (max-width: 768px) {
		.gr-hero { padding: 56px 20px 60px; }
		.gr-features-grid { grid-template-columns: 1fr; }
		.gr-impl-grid {
			grid-template-columns: 1fr;
			max-width: 400px;
		}
		.gr-impl-connector {
			flex-direction: row;
			width: 100%;
			justify-content: center;
		}
		.gr-impl-line { width: 40px; height: 2px; }
		.gr-usecases-grid { flex-direction: column; align-items: center; }
		.gr-usecase-card:nth-child(even) { transform: none; }
		.gr-usecase-card:nth-child(even).visible { transform: none; }
		.gr-usecase-card:nth-child(even):hover { transform: translateY(-4px); }
		.gr-home section { padding: 80px 20px; }
	}
</style>

<script>
	// Prism section IntersectionObserver
	const prismSection = document.getElementById('gr-prism-section');
	if (prismSection) {
		const prismObs = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
				}
			});
		}, { threshold: 0.3 });
		prismObs.observe(prismSection);
	}

	// Reveal animation for feature cards and use case cards
	const reveals = document.querySelectorAll('[data-reveal]');
	if ('IntersectionObserver' in window) {
		const revealObs = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
					revealObs.unobserve(entry.target);
				}
			});
		}, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
		reveals.forEach((el, i) => {
			(el as HTMLElement).style.transitionDelay = `${(i % 4) * 0.1}s`;
			(el as HTMLElement).style.transitionDuration = '0.6s';
			(el as HTMLElement).style.transitionProperty = 'opacity, transform';
			revealObs.observe(el);
		});
	} else {
		reveals.forEach(el => el.classList.add('visible'));
	}

	// Subtle parallax on orbs relative to mouse
	document.addEventListener('mousemove', (e) => {
		const x = (e.clientX / window.innerWidth - 0.5) * 2;
		const y = (e.clientY / window.innerHeight - 0.5) * 2;
		const orbs = document.querySelectorAll('.gr-orb');
		orbs.forEach((orb, i) => {
			const factor = (i + 1) * 8;
			(orb as HTMLElement).style.transform = `translate(${x * factor}px, ${y * factor}px)`;
		});
	});

	document.querySelectorAll('.gr-install-copy').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const box = btn.closest('.gr-install-box');
			const code = box?.querySelector('.gr-install-cmd');
			const text = code?.textContent?.trim() ?? '';
			if (!text) return;
			try {
				await navigator.clipboard.writeText(text);
				const lab = btn.querySelector('.gr-install-copy-label');
				if (lab) {
					const prev = lab.textContent;
					lab.textContent = 'Copied!';
					setTimeout(() => {
						lab.textContent = prev ?? 'Copy';
					}, 1600);
				}
			} catch {
				/* ignore */
			}
		});
	});

	document.querySelectorAll('.gr-impl-cmd[data-copy-text]').forEach((el) => {
		el.addEventListener('click', async () => {
			const btn = el as HTMLButtonElement;
			const text = btn.dataset.copyText?.trim() ?? '';
			if (!text) return;
			try {
				await navigator.clipboard.writeText(text);
				const defaultLabel = btn.dataset.defaultLabel ?? btn.textContent ?? '';
				btn.textContent = 'Copied!';
				setTimeout(() => {
					btn.textContent = defaultLabel;
				}, 1500);
			} catch {
				/* ignore */
			}
		});
	});

	document.querySelectorAll('.gr-home a[href^="#"]').forEach((el) => {
		el.addEventListener('click', (e) => {
			const href = el.getAttribute('href');
			if (!href || href.length < 2) return;
			const target = document.querySelector(href);
			if (!(target instanceof HTMLElement)) return;
			e.preventDefault();
			target.scrollIntoView({ behavior: 'smooth', block: 'start' });
		});
	});
</script>
