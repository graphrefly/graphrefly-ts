</style>

<script>
/* ═══ FLIP BOARD ═══ */
const VERBS = ['drowning in','chasing','losing sleep over','firefighting','second-guessing','babysitting','re-reading'];
const NOUNS = ['emails.','alerts.','Slack threads.','dashboards.','pull requests.','market feeds.','incident tickets.','spreadsheets.'];

function buildFlipTrack(items, cls) {
  return items.concat([items[0]]).map(t => `<span class="gr-flip-item"><span class="${cls}">${t}</span></span>`).join('');
}

const vt = document.getElementById('gr-verb-track');
const nt = document.getElementById('gr-noun-track');
if (vt && nt) {
  vt.innerHTML = buildFlipTrack(VERBS, 'gr-verb-word');
  nt.innerHTML = buildFlipTrack(NOUNS, 'gr-noun-word');

  let vi = 0, ni = 0;

  function flipTo(track, index, total) {
    const pct = -(index * (100 / (total + 1)));
    track.classList.remove('gr-no-transition');
    track.classList.add('gr-animate');
    track.style.transform = `translateY(${pct}%)`;
    if (index >= total) {
      setTimeout(() => {
        track.classList.remove('gr-animate');
        track.classList.add('gr-no-transition');
        track.style.transform = 'translateY(0%)';
        track.offsetHeight;
        track.classList.remove('gr-no-transition');
      }, 450);
    }
  }

  /* On resize, snap current position without animation */
  function snapFlipPositions() {
    [{ track: vt, index: vi, total: VERBS.length },
     { track: nt, index: ni, total: NOUNS.length }].forEach(({ track, index, total }) => {
      track.classList.remove('gr-animate');
      track.classList.add('gr-no-transition');
      const pct = -(index * (100 / (total + 1)));
      track.style.transform = `translateY(${pct}%)`;
      track.offsetHeight;
      track.classList.remove('gr-no-transition');
    });
  }

  let resizeRaf;
  window.addEventListener('resize', () => {
    if (resizeRaf) cancelAnimationFrame(resizeRaf);
    resizeRaf = requestAnimationFrame(snapFlipPositions);
  });

  setInterval(() => { vi++; flipTo(vt, vi, VERBS.length); if (vi >= VERBS.length) vi = 0; }, 2800);
  setTimeout(() => {
    setInterval(() => { ni++; flipTo(nt, ni, NOUNS.length); if (ni >= NOUNS.length) ni = 0; }, 1900);
  }, 800);
}


/* ═══ HEADACHE SCROLL ═══ */
function revealVisibleHeadaches() {
  /* Re-query DOM every time — essential after Astro view-transition swaps */
  document.querySelectorAll('.gr-headache-row').forEach(r => {
    const rect = r.getBoundingClientRect();
    const visible = rect.top < window.innerHeight && rect.bottom > 0;
    if (visible) r.classList.add('gr-revealed');
  });
}

function setupHeadacheObserver() {
  const rows = document.querySelectorAll('.gr-headache-row');
  const ho = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('gr-revealed'); });
  }, { threshold: [0.05, 0.3], rootMargin: '0px 0px -5% 0px' });
  rows.forEach(r => ho.observe(r));
}

setupHeadacheObserver();
revealVisibleHeadaches();
window.addEventListener('resize', revealVisibleHeadaches);
document.addEventListener('astro:page-load', () => { setupHeadacheObserver(); revealVisibleHeadaches(); });
document.addEventListener('astro:after-swap', () => { setTimeout(revealVisibleHeadaches, 100); });


/* ═══ PYRAMID ═══ */
const reqData = {
  creation: { title: 'LLM-Safe Creation', body: 'LLMs compose graphs structurally — like SQL for data flows — not arbitrary code. <strong>Constrained error space means the graph is correct on first pass</strong>, not after three debug cycles. Node-internal functions are simple and testable in isolation; composition bugs are the hard ones, and graph eliminates them structurally.' },
  audit: { title: 'Human Audit', body: 'Every node is observable. Every derivation has a causal chain. Ask "why was this flagged?" and get a <strong>structural answer — not a log dump, not "the model said so."</strong> Unlike OpenTelemetry (post-hoc), GraphReFly audit is live: inspect any node at any moment during runtime, not just after the fact.' },
  security: { title: 'Security', body: 'Per-node access control via Actor/Guard primitives. <strong>Multi-tenant, multi-agent isolation.</strong> Different agents see different subgraphs. The graph enforces boundaries the LLM cannot circumvent — even if the LLM tries to access nodes outside its permitted scope, the topology itself is the firewall.' },
  symmetry: { title: 'Human / LLM Symmetry', body: 'Either side can compose, review, or modify the graph. LLM composes &rarr; human reviews topology. Human composes &rarr; LLM audits correctness. LLM A composes &rarr; LLM B audits &rarr; human approves. <strong>Same structure, same tools, no translation layer.</strong> Reviewing a GraphSpec diff is easier than reviewing a code diff — for both humans and LLMs.' }
};

document.querySelectorAll('.gr-pyramid-block').forEach(block => {
  block.addEventListener('click', () => {
    const req = block.dataset.req;
    const data = reqData[req];
    if (!data) return;
    document.querySelectorAll('.gr-pyramid-block').forEach(b => b.classList.remove('gr-active'));
    block.classList.add('gr-active');
    const dt = document.getElementById('gr-detail-title');
    const db = document.getElementById('gr-detail-body');
    if (dt) dt.innerHTML = data.title;
    if (db) db.innerHTML = data.body;
  });
});


/* ═══ CORE TOGGLES (whole row) ═══ */
document.querySelectorAll('.gr-core-row').forEach(row => {
  row.addEventListener('click', () => {
    row.classList.toggle('active');
    const icon = row.querySelector('.gr-core-icon');
    if (icon) icon.innerHTML = row.classList.contains('active') ? '\u2713' : '\u2717';
  });
});


/* ═══ CLIPBOARD ═══ */
function grCopy(text) {
  navigator.clipboard.writeText(text).then(() => {
    const t = document.getElementById('gr-toast');
    if (t) { t.classList.add('gr-show'); setTimeout(() => t.classList.remove('gr-show'), 1800); }
  });
}

document.querySelectorAll('[data-copy]').forEach(el => {
  el.addEventListener('click', (e) => {
    if (e.target.closest('a')) return; // don't intercept link clicks
    grCopy(el.dataset.copy);
  });
});
</script>
