@media (max-width: 600px) {
  .gr-hero { padding: calc(var(--sl-nav-height, 4rem) + 1rem) 1.5rem 3rem; }
  .gr-headaches { padding: 3rem 0; }
  .gr-headaches-header { padding: 0 1.5rem 2rem; }
  .gr-headache-pain, .gr-headache-solution { padding: 1.5rem; }
  .gr-requirements { padding: 3rem 1.5rem 2rem; }
  .gr-core { padding: 3rem 1.5rem; }
  .gr-cta { padding: 4rem 1.5rem 2.5rem; }
  .gr-footer { flex-direction: column; align-items: flex-start; }
