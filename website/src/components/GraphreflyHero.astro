<style is:global>
@import url("https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;500;600;700;800;900&family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap");

/* ── Break out of Starlight wrappers ── */
.sl-markdown-content:has(.gr-home) { max-width: 100% !important; }
.content-panel:has(.gr-home) { max-width: 100% !important; padding: 0 !important; }
.content-panel:has(.gr-home) .sl-container { max-width: 100% !important; padding: 0 !important; }
.content-panel:has(.gr-home) .hero { display: none; }
.content-panel:has(.gr-home) > .sl-container > .sl-markdown-content { margin-top: 0 !important; }
.sl-markdown-content:has(.gr-home) > *:first-child { margin-top: 0 !important; }
main:has(.gr-home) { margin: 0 !important; padding: 0 !important; }
html:has(.gr-home) { scroll-behavior: smooth; }

/* ── Splash tokens (scoped to .gr-home) ── */
.gr-home {
  --ice: #F4F7F9;
  --ice-warm: #ECEFF2;
  --paper: #FFFFFF;
  --navy: #0A1628;
  --navy-deep: #050E1A;
  --navy-mid: #1A2940;
  --ink: #07121E;
  --ink-mute: #5C6675;
  --ink-faint: #98A0AC;
  --rule: rgba(7,18,30,0.10);
  --rule-deep: rgba(7,18,30,0.22);
  --lime: #C8FF00;
  --lime-deep: #9BC400;
  --magenta: #FF2D75;
  --red: #FF3B30;
  --display: 'Big Shoulders Display', system-ui, sans-serif;
  --sans: 'Sora', system-ui, sans-serif;
  --mono: 'JetBrains Mono', ui-monospace, monospace;

  background: var(--ice);
  color: var(--ink);
  font-family: var(--sans);
  font-size: 15px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  max-width: none;
  width: 100%;
}

.gr-home a { color: inherit; text-decoration: none; }
.gr-home * { box-sizing: border-box; }

/* ─── HERO ─── */
.gr-hero {
  max-width: 1300px;
  margin: 0 auto;
  padding: 80px 40px 0;
  text-align: center;
  position: relative;
}
.gr-hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--mono); font-size: 11.5px; font-weight: 500;
  letter-spacing: 0.10em; text-transform: uppercase;
  color: var(--ink-mute);
  border: 1px solid var(--rule);
  background: var(--paper);
  padding: 6px 12px; border-radius: 999px;
  margin-bottom: 32px;
}
.gr-hero-badge-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--lime); box-shadow: 0 0 8px rgba(200,255,0,0.7);
  animation: gr-dotPulse 2s ease-in-out infinite;
}
@keyframes gr-dotPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

.gr-hero-h1 {
  font-family: var(--display);
  font-weight: 800;
  font-size: clamp(48px, 8.5vw, 115px);
  line-height: 0.86;
  letter-spacing: -0.045em;
  text-transform: uppercase;
  margin: 0;
  color: var(--ink);
  border: 0 !important;
  padding: 0 !important;
  display: flex;
  justify-content: space-evenly;
  align-items: baseline;
  gap: 0.15em;
}
.gr-hero-word { display: inline-block; white-space: nowrap; }
@media (max-width: 700px) {
  .gr-hero-h1 { white-space: normal; }
}
.gr-hero-accent {
  display: inline-block;
  background: linear-gradient(180deg, var(--lime) 0%, var(--lime-deep) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.gr-hero-op { font-weight: 400; color: var(--ink-mute); }
.gr-hero-implicit {
  font-weight: 400; color: var(--ink-mute);
  font-size: 0.55em; letter-spacing: 0;
  vertical-align: 0.18em; text-transform: none;
}

.gr-hero-sub {
  max-width: 720px; margin: 36px auto 0;
  font-family: var(--sans);
  font-size: 19px; line-height: 1.55; font-weight: 400;
  color: var(--ink-mute);
}
.gr-hero-sub b { color: var(--ink); font-weight: 600; }

.gr-lang-row {
  display: inline-flex; gap: 4px; align-items: center;
  margin-top: 36px;
  padding: 4px; border: 1px solid var(--rule-deep);
  border-radius: 999px;
  background: var(--paper);
}
.gr-lang-pill {
  font-family: var(--sans); font-size: 12px; font-weight: 600;
  padding: 8px 18px; border-radius: 999px;
  border: 0; background: transparent;
  color: var(--ink-mute); cursor: pointer;
  letter-spacing: 0.04em;
  transition: all 0.18s;
}
.gr-lang-pill:hover { color: var(--ink); }
.gr-lang-pill.gr-lang-active { background: var(--ink); color: var(--ice); }

.gr-hero-ctas {
  margin-top: 22px;
  display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
}
.gr-home a.gr-btn-primary {
  font-family: var(--sans); font-size: 14.5px; font-weight: 600;
  background: var(--ink); color: var(--ice);
  padding: 16px 28px; border-radius: 999px;
  transition: all 0.18s;
  display: inline-flex; align-items: center; gap: 8px;
  cursor: pointer; border: 0;
  text-decoration: none;
}
.gr-home a.gr-btn-primary:hover { background: var(--navy); transform: translateY(-1px); }
.gr-btn-secondary {
  font-family: var(--mono); font-size: 12.5px; font-weight: 500;
  color: var(--ink); border: 1px solid var(--rule-deep);
  padding: 16px 22px; border-radius: 999px;
  background: var(--paper);
  letter-spacing: 0.02em; cursor: pointer;
}
.gr-btn-secondary[data-gr-lang-target] { display: none; }
.gr-btn-secondary[data-gr-lang-target].gr-show { display: inline-flex; align-items: center; }
.gr-btn-secondary:hover { border-color: var(--ink); }
.gr-btn-secondary .gr-prompt { color: var(--ink-faint); margin-right: 8px; }

/* ─── SHOWCASE ─── */
.gr-showcase {
  margin: 60px auto 0;
  max-width: 1300px; padding: 0 40px;
  position: relative;
}
.gr-showcase-frame {
  position: relative;
  background: var(--navy);
  border-radius: 28px;
  overflow: hidden;
  box-shadow:
    0 1px 0 rgba(255,255,255,0.04) inset,
    0 80px 100px -50px rgba(7,18,30,0.40),
    0 30px 50px -30px rgba(7,18,30,0.30);
  aspect-ratio: 16/8;
}
.gr-showcase-frame::before {
  content: ''; position: absolute; inset: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 60% 40% at 50% 40%, rgba(200,255,0,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 40% 30% at 20% 80%, rgba(255,45,117,0.05) 0%, transparent 60%);
}
.gr-showcase-stage { width: 100%; height: 100%; position: relative; }
.gr-showcase-stage svg { width: 100%; height: 100%; }
.gr-showcase-nP, .gr-showcase-nD {
  transform-origin: center;
  animation: gr-showcaseBreathe 5s ease-in-out infinite;
}
.gr-showcase-nD { animation-delay: 2.5s; }
@keyframes gr-showcaseBreathe { 0%, 100% { opacity: 0.55; } 50% { opacity: 1; } }
.gr-showcase-data {
  fill: var(--lime); filter: drop-shadow(0 0 12px rgba(200,255,0,0.8));
  animation: gr-showcaseTravel 5s ease-in-out infinite;
}
@keyframes gr-showcaseTravel {
  0%   { transform: translateX(-280px); opacity: 0; }
  15%  { opacity: 1; }
  50%  { transform: translateX(280px); opacity: 1; }
  60%  { opacity: 0; }
  100% { transform: translateX(280px); opacity: 0; }
}
.gr-showcase-dirty {
  fill: none; stroke: #FBBF24; stroke-width: 1.5; stroke-dasharray: 3 3;
  animation: gr-showcaseTravel 5s ease-in-out infinite;
  animation-delay: -0.5s;
}
.gr-showcase-badges {
  position: absolute; top: 24px; left: 24px; right: 24px;
  display: flex; justify-content: space-between;
  font-family: var(--mono); font-size: 10.5px;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: rgba(255,255,255,0.45);
  z-index: 5; pointer-events: none;
}
.gr-showcase-live::before {
  content: ''; display: inline-block; width: 6px; height: 6px; border-radius: 50%;
  background: var(--lime); margin-right: 6px; vertical-align: middle;
  box-shadow: 0 0 6px var(--lime);
}
.gr-showcase-label {
  position: absolute; bottom: 32px; left: 32px; z-index: 5;
}
.gr-showcase-label-k {
  font-family: var(--mono); font-size: 10.5px;
  color: var(--lime); letter-spacing: 0.16em; text-transform: uppercase;
  margin-bottom: 6px;
}
.gr-showcase-label-v {
  font-family: var(--display); font-weight: 700;
  font-size: 40px; line-height: 1; color: var(--ice);
  letter-spacing: -0.03em; text-transform: uppercase;
}
.gr-showcase-chips {
  position: absolute; bottom: 32px; right: 32px;
  display: flex; gap: 10px; z-index: 5;
}
.gr-showcase-chip {
  font-family: var(--mono); font-size: 11px; color: var(--ice);
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.18);
  padding: 8px 14px; border-radius: 999px;
  backdrop-filter: blur(6px);
}

/* ─── SECTION CHROME ─── */
.gr-section {
  max-width: 1300px;
  margin: 140px auto 0;
  padding: 0 40px;
}
.gr-ey {
  font-family: var(--mono); font-size: 11.5px;
  color: var(--lime-deep); letter-spacing: 0.18em; text-transform: uppercase;
  margin-bottom: 18px;
}
.gr-ey::before { content: '— '; }
.gr-section-h2 {
  font-family: var(--display); font-weight: 800;
  font-size: clamp(48px, 7vw, 96px); line-height: 0.9;
  letter-spacing: -0.04em; margin: 0 0 18px;
  text-transform: uppercase;
  color: var(--ink);
  border: 0 !important;
  padding: 0 !important;
}
.gr-h-out {
  -webkit-text-stroke: 1.5px var(--ink);
  color: transparent;
  font-weight: 400;
  letter-spacing: 0;
}
.gr-h-out::selection {
  background: rgba(51, 144, 255, 0.25);
  color: var(--ink);
  -webkit-text-fill-color: var(--ink);
}
.gr-h-accent {
  background: linear-gradient(180deg, var(--lime) 0%, var(--lime-deep) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.gr-intro {
  font-family: var(--sans); font-size: 17px; line-height: 1.6;
  color: var(--ink-mute); max-width: 60ch;
  margin: 0 0 56px;
}
.gr-intro b { color: var(--ink); font-weight: 600; }

/* ─── SPEC SHEET ─── */
.gr-spec-sheet { margin-top: 120px; }
.gr-spec-sheet .gr-section-h2 { max-width: 14ch; margin-bottom: 64px; }
.gr-spec-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; background: var(--rule-deep);
  border: 1px solid var(--rule-deep);
  border-radius: 24px; overflow: hidden;
}
.gr-spec-cell {
  background: var(--paper);
  padding: 36px 28px;
  display: flex; flex-direction: column; justify-content: space-between;
  min-height: 240px;
  transition: background 0.25s ease, color 0.25s ease;
  cursor: default;
}
.gr-spec-cell:hover { background: var(--navy); color: var(--ice); }
.gr-spec-cell:hover .gr-spec-ttl { color: var(--lime); }
.gr-spec-cell:hover .gr-spec-descr { color: rgba(244,247,249,0.7); }
.gr-spec-cell:hover .gr-spec-meta { color: var(--ice-warm); }
.gr-spec-cell:hover .gr-spec-big .gr-spec-un { color: var(--ice-warm); }
.gr-spec-cell .gr-spec-descr code {
  font-family: var(--mono);
  font-size: 0.9em;
  color: var(--ink);
  background: rgba(7,18,30,0.06);
  padding: 1px 7px;
  border-radius: 4px;
  transition: background 0.25s ease, color 0.25s ease;
}
.gr-spec-cell:hover .gr-spec-descr code {
  color: var(--ice);
  background: rgba(255,255,255,0.12);
}
.gr-spec-ttl {
  font-family: var(--mono); font-size: 11.5px;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--ink-mute);
  margin-bottom: 18px;
}
.gr-spec-big {
  font-family: var(--display); font-weight: 800;
  font-size: 80px; line-height: 0.85;
  letter-spacing: -0.04em;
}
.gr-spec-un {
  font-family: var(--sans); font-size: 18px; font-weight: 400;
  color: var(--ink-mute); margin-left: 6px; letter-spacing: -0.01em;
  text-transform: lowercase;
}
.gr-spec-descr {
  margin-top: 14px;
  font-family: var(--sans); font-size: 14px;
  color: var(--ink-mute); line-height: 1.5;
}
.gr-spec-meta {
  margin-top: 18px;
  font-family: var(--mono); font-size: 11px;
  color: var(--ink); letter-spacing: 0.02em;
}
.gr-spec-meta::before { content: '— '; color: var(--lime-deep); }

/* ─── HEADACHES (Three harness gaps) ─── */
.gr-headaches { margin-top: 160px; }
.gr-gap-list { display: flex; flex-direction: column; gap: 20px; }
.gr-gap-row {
  display: grid; grid-template-columns: 1fr 0fr;
  gap: 0; border-radius: 24px; overflow: hidden;
  border: 1px solid var(--rule);
  background: var(--paper);
  transition: grid-template-columns 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.gr-gap-row.gr-revealed { grid-template-columns: 1fr 1fr; }

.gr-gap-pain {
  padding: 40px 36px;
  display: flex; flex-direction: column;
  gap: 16px; min-width: 0;
  position: relative; overflow: hidden;
  transition: background 0.6s, color 0.6s;
}
.gr-gap-row.gr-revealed .gr-gap-pain { background: rgba(255,59,48,0.04); }
.gr-gap-num {
  font-family: var(--display); font-weight: 800;
  font-size: 28px; line-height: 1; letter-spacing: -0.04em;
  color: var(--ink-faint);
  display: flex; align-items: center; gap: 14px;
  transition: color 0.6s;
}
.gr-gap-row.gr-revealed .gr-gap-num { color: var(--red); }
.gr-gap-num::after {
  content: 'PAIN'; font-family: var(--mono); font-size: 10.5px;
  letter-spacing: 0.18em; color: var(--ink-faint); font-weight: 500;
  border: 1px solid var(--rule);
  padding: 4px 10px; border-radius: 999px;
  transition: color 0.6s, border-color 0.6s;
}
.gr-gap-row.gr-revealed .gr-gap-num::after {
  color: var(--red); border-color: rgba(255,59,48,0.4);
}
.gr-gap-pain .gr-gap-h {
  font-family: var(--display); font-weight: 700;
  font-size: clamp(28px, 3vw, 40px); line-height: 1;
  letter-spacing: -0.03em; margin: 0;
  text-transform: uppercase;
  transition: color 0.6s;
  border: 0 !important;
  padding: 0 !important;
}
.gr-gap-row.gr-revealed .gr-gap-pain .gr-gap-h { color: var(--red); }
.gr-gap-pain p {
  font-family: var(--sans); font-size: 15px; line-height: 1.6;
  color: var(--ink-mute); margin: 0; max-width: 50ch;
}
.gr-gap-pain p strong { color: var(--ink); font-weight: 600; }
.gr-gap-glyph {
  position: absolute; bottom: -10px; right: -10px;
  width: 180px; height: 180px; opacity: 0.05;
  pointer-events: none;
  transition: opacity 0.6s, transform 0.6s, color 0.6s;
  transform: rotate(-10deg);
}
.gr-gap-row.gr-revealed .gr-gap-pain .gr-gap-glyph {
  opacity: 0.14; transform: rotate(0); color: var(--red);
}

.gr-gap-solution {
  padding: 40px 36px;
  background: var(--navy);
  color: var(--ice);
  display: flex; flex-direction: column;
  gap: 14px; min-width: 0;
  position: relative; overflow: hidden;
  opacity: 0;
  transition: opacity 0.45s 0.3s;
}
.gr-gap-row.gr-revealed .gr-gap-solution { opacity: 1; }
.gr-gap-solution::before {
  content: ''; position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(circle 400px at 80% 50%, rgba(200,255,0,0.08), transparent 60%);
}
.gr-gap-solution > * { position: relative; z-index: 2; }
.gr-gap-badge {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: var(--mono); font-size: 10.5px;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--lime); align-self: flex-start;
  padding: 6px 12px; border: 1px solid rgba(200,255,0,0.3);
  border-radius: 999px; background: rgba(200,255,0,0.06);
}
.gr-gap-badge-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--lime); box-shadow: 0 0 6px var(--lime);
}
.gr-gap-solution .gr-gap-h {
  font-family: var(--display); font-weight: 700;
  font-size: clamp(28px, 3vw, 40px); line-height: 1;
  letter-spacing: -0.03em; margin: 0;
  text-transform: uppercase;
  color: var(--ice);
  border: 0 !important;
  padding: 0 !important;
}
.gr-gap-solution .gr-gap-h em {
  font-style: normal;
  background: linear-gradient(180deg, var(--lime) 0%, var(--lime-deep) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.gr-gap-solution p {
  font-family: var(--sans); font-size: 15px; line-height: 1.6;
  color: rgba(244,247,249,0.78); margin: 0; max-width: 48ch;
}
.gr-home a.gr-gap-demo {
  display: inline-flex; align-items: center; gap: 8px;
  margin-top: 12px; align-self: flex-start;
  font-family: var(--mono); font-size: 11.5px;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--ink); background: var(--lime);
  padding: 10px 16px; border-radius: 999px;
  font-weight: 600;
  transition: background 0.18s;
  text-decoration: none;
}
.gr-home a.gr-gap-demo:hover { background: var(--ice); color: var(--ink); }

/* ─── PYRAMID ─── */
.gr-pyramid-section { margin-top: 180px; }
.gr-pyramid-wrap {
  display: grid; grid-template-columns: minmax(0, 560px) 1fr;
  gap: 56px; align-items: start;
  background: var(--paper);
  border: 1px solid var(--rule);
  border-radius: 24px;
  padding: 56px;
}
.gr-pyramid {
  display: flex; flex-direction: column; align-items: stretch; gap: 0;
  width: 100%; max-width: 480px; margin: 0 auto;
}
.gr-pyr-tier {
  display: grid; gap: 12px;
  width: 100%; align-items: stretch;
}
.gr-pyr-t1 { grid-template-columns: 1fr; max-width: 260px; margin: 0 auto; }
.gr-pyr-t2 { grid-template-columns: 1fr 1fr; max-width: 380px; margin: 0 auto; }
.gr-pyr-t3 { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
.gr-pyr-connector {
  width: 2px; height: 24px;
  background: var(--rule-deep); margin: 12px auto;
  border-radius: 1px;
}
.gr-pyr-block {
  border: 1.5px solid var(--rule-deep);
  background: var(--paper);
  border-radius: 18px;
  padding: 20px 18px;
  cursor: pointer;
  display: flex; flex-direction: column; gap: 4px;
  text-align: center;
  transition: all 0.22s ease;
  position: relative;
}
.gr-pyr-block:hover {
  border-color: var(--ink);
  background: rgba(7,18,30,0.04);
}
.gr-pyr-block.gr-active {
  border-color: var(--lime-deep);
  background: linear-gradient(180deg, rgba(200,255,0,0.10), rgba(200,255,0,0.04));
  box-shadow: 0 12px 28px -16px rgba(155,196,0,0.5);
}
.gr-pyr-title {
  font-family: var(--display); font-weight: 700;
  font-size: 16px; line-height: 1.15;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  color: var(--ink);
}
.gr-pyr-sub {
  font-family: var(--sans); font-size: 12px;
  color: var(--ink-mute); line-height: 1.4;
}

.gr-pyramid-detail {
  background: var(--navy);
  color: var(--ice);
  border-radius: 20px;
  padding: 40px 36px;
  min-height: 380px;
  display: flex; flex-direction: column; gap: 18px;
  position: relative; overflow: hidden;
}
.gr-pyramid-detail::before {
  content: ''; position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(circle 500px at 80% 0%, rgba(200,255,0,0.08), transparent 65%);
}
.gr-pyramid-detail > * { position: relative; z-index: 2; }
.gr-pd-label {
  font-family: var(--mono); font-size: 10.5px;
  color: var(--lime); letter-spacing: 0.18em; text-transform: uppercase;
}
.gr-pd-title {
  font-family: var(--display); font-weight: 800;
  font-size: clamp(32px, 4vw, 48px); line-height: 0.95;
  letter-spacing: -0.03em; text-transform: uppercase;
  color: var(--ice); margin: 0;
  border: 0 !important;
  padding: 0 !important;
}
.gr-pd-body {
  font-family: var(--sans); font-size: 15px; line-height: 1.7;
  color: rgba(244,247,249,0.78); margin: 0;
}
.gr-pd-body strong { color: var(--lime); font-weight: 600; }

/* ─── FIVE COMPONENTS ─── */
.gr-comp-section { margin-top: 180px; }
.gr-comp-list {
  background: var(--paper);
  border: 1px solid var(--rule);
  border-radius: 24px; overflow: hidden;
}
.gr-comp-row {
  display: grid;
  grid-template-columns: 220px 1fr auto;
  gap: 32px;
  align-items: center;
  padding: 28px 36px;
  border-bottom: 1px solid var(--rule);
  cursor: pointer;
  user-select: none;
  transition: background 0.2s;
}
.gr-comp-row:last-child { border-bottom: none; }
.gr-comp-row:hover { background: var(--navy); }
.gr-comp-row.gr-active:hover .gr-comp-name { color: var(--ice); }
.gr-comp-row:not(.gr-active):hover .gr-comp-name { color: rgba(244,247,249,0.45); text-decoration-color: rgba(255,45,117,0.55); }
.gr-comp-row:hover .gr-comp-desc { color: rgba(244,247,249,0.75); }
.gr-comp-row:hover .gr-comp-broken { color: var(--magenta); }
.gr-comp-row.gr-active:hover .gr-comp-tag { border-color: var(--lime); background: rgba(200,255,0,0.18); color: var(--lime); }
.gr-comp-row:not(.gr-active):hover .gr-comp-tag { border-color: var(--magenta); background: rgba(255,45,117,0.20); color: var(--magenta); }

.gr-comp-toggle { display: flex; align-items: center; gap: 14px; }
.gr-comp-icon {
  width: 26px; height: 26px; border-radius: 8px;
  display: grid; place-items: center;
  font-family: var(--sans); font-weight: 700; font-size: 14px;
  transition: all 0.2s;
  flex-shrink: 0;
}
.gr-comp-row.gr-active .gr-comp-icon { background: var(--lime); color: var(--ink); }
.gr-comp-row:not(.gr-active) .gr-comp-icon { background: rgba(255,45,117,0.12); color: var(--magenta); }
.gr-comp-name {
  font-family: var(--mono); font-size: 14px; font-weight: 500;
  transition: color 0.2s;
}
.gr-comp-row.gr-active .gr-comp-name { color: var(--ink); }
.gr-comp-row:not(.gr-active) .gr-comp-name { color: var(--ink-faint); text-decoration: line-through; text-decoration-color: rgba(255,45,117,0.4); }

.gr-comp-content { min-width: 0; }
.gr-comp-desc {
  font-family: var(--sans); font-size: 14.5px; line-height: 1.55;
  color: var(--ink-mute);
}
.gr-comp-broken {
  font-family: var(--sans); font-size: 14.5px; line-height: 1.55;
  color: var(--magenta);
  display: none;
}
.gr-comp-row:not(.gr-active) .gr-comp-desc { display: none; }
.gr-comp-row:not(.gr-active) .gr-comp-broken { display: block; }

.gr-comp-enables { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }
.gr-comp-tag {
  font-family: var(--mono); font-size: 10.5px;
  font-weight: 500; letter-spacing: 0.04em;
  padding: 5px 11px; border-radius: 999px;
  border: 1px solid;
  white-space: nowrap;
  transition: all 0.2s;
}
.gr-comp-row.gr-active .gr-comp-tag {
  border-color: rgba(155,196,0,0.5);
  color: var(--lime-deep);
  background: rgba(200,255,0,0.10);
}
.gr-comp-row:not(.gr-active) .gr-comp-tag {
  border-color: rgba(255,45,117,0.4);
  color: var(--magenta);
  background: rgba(255,45,117,0.06);
}

/* ─── CTA BAND ─── */
.gr-cta-band { margin: 180px auto 0; max-width: 1300px; }
.gr-cta-inner {
  background: var(--navy);
  margin: 0 40px;
  border-radius: 32px;
  padding: 72px 60px;
  position: relative; overflow: hidden;
}
.gr-cta-inner::before {
  content: ''; position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(circle 600px at 80% 50%, rgba(200,255,0,0.10), transparent 65%);
}
.gr-cta-head {
  position: relative; z-index: 2;
  text-align: center; margin-bottom: 48px;
}
.gr-cta-ey {
  font-family: var(--mono); font-size: 11.5px;
  color: var(--lime); letter-spacing: 0.18em; text-transform: uppercase;
  margin-bottom: 14px;
}
.gr-cta-h {
  font-family: var(--display); font-weight: 800;
  font-size: clamp(48px, 7vw, 96px); line-height: 0.9;
  letter-spacing: -0.04em; text-transform: uppercase;
  margin: 0; color: var(--ice);
  border: 0 !important;
  padding: 0 !important;
}
.gr-cta-h em {
  font-style: normal;
  background: linear-gradient(180deg, var(--lime) 0%, var(--lime-deep) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.gr-cta-sub {
  margin: 18px auto 0; max-width: 540px;
  font-family: var(--sans); font-size: 16px; line-height: 1.6;
  color: rgba(244,247,249,0.7);
}

.gr-install-cards {
  position: relative; z-index: 2;
  display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
  max-width: 720px; margin: 0 auto;
}
.gr-install-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 18px; padding: 24px;
  cursor: pointer;
  display: flex; flex-direction: column; gap: 12px;
  transition: all 0.2s;
}
.gr-install-card:hover { background: var(--lime); border-color: var(--lime); }
.gr-install-card:hover .gr-install-lang { color: var(--ink); opacity: 0.55; }
.gr-install-card:hover .gr-install-cmd { color: var(--ink); }
.gr-home .gr-install-card:hover a.gr-install-gh { border-color: var(--ink); color: var(--ink); }
.gr-install-lang {
  font-family: var(--mono); font-size: 10.5px;
  color: rgba(244,247,249,0.6);
  letter-spacing: 0.18em; text-transform: uppercase;
  font-weight: 500;
}
.gr-install-cmd {
  font-family: var(--mono); font-size: 16px; font-weight: 500;
  color: var(--ice); transition: color 0.18s;
}
.gr-install-pr { color: rgba(244,247,249,0.45); margin-right: 8px; }
.gr-install-card:hover .gr-install-pr { color: rgba(7,18,30,0.5); }
.gr-home a.gr-install-gh {
  align-self: flex-start;
  font-family: var(--mono); font-size: 11px;
  color: rgba(244,247,249,0.6);
  border: 1px solid rgba(255,255,255,0.18);
  padding: 6px 12px; border-radius: 999px;
  margin-top: 4px;
  letter-spacing: 0.06em; text-transform: uppercase;
  transition: all 0.18s;
  text-decoration: none;
}

/* ─── FOOTER ─── */
.gr-foot {
  max-width: 1300px;
  margin: 120px auto 0;
  padding: 60px 40px 28px;
  border-top: 1px solid var(--rule);
  display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
  gap: 40px;
  font-family: var(--sans); font-size: 13.5px;
}
.gr-foot-brand {
  font-family: var(--display); font-weight: 800;
  font-size: 36px; letter-spacing: -0.03em;
  text-transform: uppercase;
  color: var(--ink);
}
.gr-foot-brand small {
  display: block; font-family: var(--mono); font-size: 10.5px;
  color: var(--ink-mute); letter-spacing: 0.12em; margin-top: 8px;
  font-weight: 400; text-transform: uppercase;
}
.gr-foot-col b {
  display: block; font-size: 12px; text-transform: uppercase;
  letter-spacing: 0.12em; color: var(--ink); margin-bottom: 14px;
  font-weight: 600;
}
.gr-foot-col a {
  display: block; color: var(--ink-mute); margin-bottom: 8px;
  transition: color 0.15s;
}
.gr-foot-col a:hover { color: var(--ink); }
.gr-foot-end {
  grid-column: 1 / -1; margin-top: 36px;
  border-top: 1px solid var(--rule); padding-top: 18px;
  display: flex; justify-content: space-between;
  font-family: var(--mono); font-size: 11px; color: var(--ink-faint);
  letter-spacing: 0.04em;
}

/* ─── TOAST ─── */
.gr-toast {
  position: fixed; bottom: 32px; left: 50%;
  transform: translateX(-50%) translateY(20px);
  padding: 12px 22px; background: var(--ink); color: var(--lime);
  font-family: var(--mono); font-size: 12px;
  letter-spacing: 0.10em; text-transform: uppercase;
  font-weight: 500;
  border-radius: 999px;
  opacity: 0; transition: all 0.3s ease;
  z-index: 200; pointer-events: none;
}
.gr-toast.gr-show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* ─── RESPONSIVE ─── */
@media (max-width: 1000px) {
  .gr-spec-grid { grid-template-columns: 1fr 1fr; }
  .gr-pyramid-wrap { grid-template-columns: 1fr; padding: 32px; }
  .gr-install-cards { grid-template-columns: 1fr; }
  .gr-comp-row { grid-template-columns: 1fr; gap: 14px; }
  .gr-comp-enables { justify-content: flex-start; }
  .gr-foot { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 700px) {
  .gr-gap-row, .gr-gap-row.gr-revealed { grid-template-columns: 1fr; }
  .gr-gap-solution { opacity: 1; }
  .gr-section { padding: 0 24px; margin-top: 100px; }
  .gr-hero { padding: 56px 24px 0; }
  .gr-showcase { padding: 0 24px; }
  .gr-cta-inner { padding: 48px 28px; margin: 0 24px; }
  .gr-foot { grid-template-columns: 1fr; padding: 60px 24px 28px; }
}
</style>

<script is:inline>
(function() {
  function init() {
    /* ═══ LANG SWITCHER ═══ */
    document.querySelectorAll('.gr-lang-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        const lang = pill.dataset.grLang;
        document.querySelectorAll('.gr-lang-pill').forEach(p => p.classList.remove('gr-lang-active'));
        pill.classList.add('gr-lang-active');
        document.querySelectorAll('[data-gr-lang-target]').forEach(el => {
          el.classList.toggle('gr-show', el.dataset.grLangTarget === lang);
        });
      });
    });

    /* ═══ HEADACHE SCROLL REVEAL ═══ */
    function revealVisibleGaps() {
      document.querySelectorAll('.gr-gap-row').forEach(r => {
        const rect = r.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) r.classList.add('gr-revealed');
      });
    }
    const gapObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('gr-revealed'); });
    }, { threshold: [0.05, 0.3], rootMargin: '0px 0px -5% 0px' });
    document.querySelectorAll('.gr-gap-row').forEach(r => gapObserver.observe(r));
    revealVisibleGaps();
    window.addEventListener('resize', revealVisibleGaps);

    /* ═══ PYRAMID ═══ */
    const reqData = {
      creation: {
        title: 'LLM-Safe Creation',
        body: 'LLMs compose graphs structurally — like SQL for data flows — not arbitrary code. <strong>Constrained error space</strong> means the graph is correct on first pass, not after three debug cycles. Node-internal functions are simple and testable in isolation; composition bugs are the hard ones, and the graph eliminates them structurally.'
      },
      audit: {
        title: 'Human Audit',
        body: 'Every node is observable. Every derivation has a causal chain. Ask "why was this flagged?" and get a <strong>structural answer</strong> — not a log dump, not "the model said so." Unlike OpenTelemetry (post-hoc), GraphReFly audit is live: inspect any node at any moment during runtime, not just after the fact.'
      },
      security: {
        title: 'Security',
        body: 'Per-node access control via Actor/Guard primitives. <strong>Multi-tenant, multi-agent isolation.</strong> Different agents see different subgraphs. The graph enforces boundaries the LLM cannot circumvent — even if the LLM tries to access nodes outside its permitted scope, the topology itself is the firewall.'
      },
      symmetry: {
        title: 'Human / LLM Symmetry',
        body: 'Either side can compose, review, or modify the graph. LLM composes → human reviews topology. Human composes → LLM audits correctness. LLM A composes → LLM B audits → human approves. <strong>Same structure, same tools, no translation layer.</strong> Reviewing a GraphSpec diff is easier than reviewing a code diff — for both humans and LLMs.'
      }
    };

    document.querySelectorAll('.gr-pyr-block').forEach(block => {
      block.addEventListener('click', () => {
        const req = block.dataset.grReq;
        const data = reqData[req];
        if (!data) return;
        document.querySelectorAll('.gr-pyr-block').forEach(b => b.classList.remove('gr-active'));
        block.classList.add('gr-active');
        const titleEl = document.getElementById('gr-pd-title');
        const bodyEl = document.getElementById('gr-pd-body');
        if (titleEl) titleEl.textContent = data.title;
        if (bodyEl) bodyEl.innerHTML = data.body;
        const label = document.querySelector('.gr-pyramid-detail .gr-pd-label');
        if (label) label.textContent = '— ' + req.charAt(0).toUpperCase() + req.slice(1);
      });
    });

    /* ═══ COMPONENT ROW TOGGLE ═══ */
    document.querySelectorAll('.gr-comp-row').forEach(row => {
      row.addEventListener('click', () => {
        row.classList.toggle('gr-active');
        const icon = row.querySelector('.gr-comp-icon');
        if (icon) icon.textContent = row.classList.contains('gr-active') ? '✓' : '✕';
      });
    });

    /* ═══ CLIPBOARD ═══ */
    function copyText(text) {
      navigator.clipboard.writeText(text).then(() => {
        const t = document.getElementById('gr-toast');
        if (t) { t.classList.add('gr-show'); setTimeout(() => t.classList.remove('gr-show'), 1600); }
      });
    }
    document.querySelectorAll('[data-gr-copy]').forEach(el => {
      el.addEventListener('click', (e) => {
        if (e.target.closest('a')) return;
        copyText(el.dataset.grCopy);
      });
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
})();
</script>
