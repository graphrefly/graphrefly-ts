---
const base = import.meta.env.BASE_URL;
---

<div class="gr-home not-content">

<!-- ═══ HERO ═══ -->
<section class="gr-hero">
  <div class="gr-hero-badge">
    <span class="gr-hero-badge-dot"></span> Reactive Graph Protocol  ·  Causal Tracing
  </div>

  <h1 class="gr-hero-h1">
    <span class="gr-hero-word">Graph</span><span class="gr-hero-op">+</span><span class="gr-hero-word">Re<span class="gr-hero-implicit">[active]</span></span><span class="gr-hero-op">=</span><span class="gr-hero-accent">Fly</span>
  </h1>

  <p class="gr-hero-sub">
    <b>GraphReFly</b> makes the future of human-AI collaboration real. <b>One reactive graph</b> where humans and AI work as peers — <b>composing, reviewing, and modifying together</b>. Changes <b>propagate</b> automatically; the model reruns only when it must. A thin harness layer lets you turn each black-box step into a verified outcome. Every flow <b>observable</b>, every change <b>auditable</b>. Step by step, <b>probability becomes predictability</b>.
  </p>

  <div class="gr-lang-row">
    <button class="gr-lang-pill gr-lang-active" data-gr-lang="ts">TypeScript</button>
    <button class="gr-lang-pill" data-gr-lang="py">Python</button>
  </div>

  <div class="gr-hero-ctas">
    <a href="#gr-install" class="gr-btn-primary">Get started <span class="gr-arrow">→</span></a>
    <button class="gr-btn-secondary gr-show" data-gr-lang-target="ts" data-gr-copy="npm i @graphrefly/graphrefly"><span class="gr-prompt">$</span>npm i @graphrefly/graphrefly</button>
    <button class="gr-btn-secondary" data-gr-lang-target="py" data-gr-copy="pip install graphrefly"><span class="gr-prompt">$</span>pip install graphrefly</button>
  </div>
</section>

<!-- ═══ SHOWCASE — full 8-stage ambient hero (~48s loop) ═══ -->
<section class="gr-showcase">
  <div class="gr-showcase-frame">
    <span class="gr-showcase-tagline">GRAPHREFLY  ·  REACTIVE GRAPH PROTOCOL  ·  CAUSAL TRACING</span>
    <div class="gr-scrubber" role="tablist" aria-label="Jump to stage">
      <button type="button" class="gr-seg gr-seg-1" data-ms="0"     title="Stage 1 · Connection lifecycle" aria-label="Stage 1 — Connection lifecycle">1</button>
      <button type="button" class="gr-seg gr-seg-2" data-ms="12000" title="Stage 2 · Diamond resolution"   aria-label="Stage 2 — Diamond resolution">2</button>
      <button type="button" class="gr-seg gr-seg-3" data-ms="17000" title="Stage 3 · Node anatomy"         aria-label="Stage 3 — Node anatomy">3</button>
      <button type="button" class="gr-seg gr-seg-4" data-ms="22000" title="Stage 4 · Four sugars"          aria-label="Stage 4 — Four sugars">4</button>
      <button type="button" class="gr-seg gr-seg-5" data-ms="27000" title="Stage 5 · Graph level"          aria-label="Stage 5 — Graph level">5</button>
      <button type="button" class="gr-seg gr-seg-6" data-ms="35000" title="Stage 6 · Orchestrate"          aria-label="Stage 6 — Orchestrate">6</button>
      <button type="button" class="gr-seg gr-seg-7" data-ms="41000" title="Stage 7 · Agent loop"           aria-label="Stage 7 — Agent loop">7</button>
    </div>

    <div class="gr-showcase-stage" aria-hidden="true">
      <svg viewBox="-400 -180 800 360" preserveAspectRatio="xMidYMid meet" class="gr-stage-svg">
        <defs>
          <radialGradient id="gr-lensGrad" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="rgba(255,255,255,0.10)" />
            <stop offset="70%" stop-color="rgba(255,255,255,0.04)" />
            <stop offset="100%" stop-color="rgba(255,255,255,0)" />
          </radialGradient>
          <!-- Generic arrowhead for directed edges; userSpaceOnUse keeps size independent of stroke-width -->
          <marker id="gr-arr" viewBox="0 0 8 8" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto" markerUnits="userSpaceOnUse">
            <polygon points="0 0, 8 4, 0 8" fill="rgba(244,247,249,0.62)"></polygon>
          </marker>
          <!-- Lime variant for the active Stage 1 edge during DATA flow -->
          <marker id="gr-arr-lime" viewBox="0 0 8 8" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto" markerUnits="userSpaceOnUse">
            <polygon points="0 0, 8 4, 0 8" fill="rgba(200,255,0,0.85)"></polygon>
          </marker>
          <!-- Larger arrowhead for Stage 3 ports — emphasis on the up/down direction labels -->
          <marker id="gr-arr-port" viewBox="0 0 14 14" markerWidth="14" markerHeight="14" refX="12" refY="7" orient="auto" markerUnits="userSpaceOnUse">
            <polygon points="0 0, 14 7, 0 14" fill="rgba(244,247,249,0.85)"></polygon>
          </marker>
          <!-- DIRTY pattern: yellow dots over translucent base.  Applied via fill="url(#gr-dirty)" on nodes in the DIRTY state. -->
          <pattern id="gr-dirty" patternUnits="userSpaceOnUse" width="7" height="7">
            <rect width="7" height="7" fill="rgba(251,191,36,0.10)"></rect>
            <circle cx="3.5" cy="3.5" r="1.4" fill="rgba(251,191,36,0.85)"></circle>
          </pattern>
        </defs>
        <g class="gr-cam">

          <!-- ═════ STAGE 1 — connection lifecycle (12s, full START→COMPLETE with DIRTY state) ═════ -->
          <g class="gr-st gr-st-1">
            <!-- Edge wrapped in opacity-animated group; arrow stays lime, group dims for gray-out -->
            <g class="gr-s1-edge-grp">
              <line class="gr-s1-edge" x1="-162" y1="0" x2="156" y2="0" marker-end="url(#gr-arr-lime)"></line>
            </g>

            <!-- Upstream general node (rounded rect close-up) at 25% width -->
            <g class="gr-s1-up" transform="translate(-200 0)">
              <rect class="gr-s1-up-shape" x="-38" y="-22" width="76" height="44" rx="10"></rect>
              <text class="gr-nl gr-s1-up-label" y="-32">upstream</text>
            </g>

            <!-- Downstream general node (rounded rect close-up) at 75% width -->
            <g class="gr-s1-dn" transform="translate(200 0)">
              <rect class="gr-s1-dn-shape" x="-38" y="-22" width="76" height="44" rx="10"></rect>
              <text class="gr-nl gr-s1-dn-label" y="-32">downstream</text>
              <text class="gr-s1-fn" y="5">fn(…)</text>
            </g>

            <!-- Six labeled messages, each travels left → right along the edge -->
            <g class="gr-s1-msg gr-s1-msg-start">
              <text y="-13" class="gr-s1-msg-lbl gr-s1-lbl-start">START</text>
              <circle cy="0" r="4" class="gr-s1-dot-slate"></circle>
            </g>

            <g class="gr-s1-msg gr-s1-msg-dirty1">
              <text y="-16" class="gr-s1-msg-lbl gr-s1-lbl-dirty">DIRTY</text>
              <line x1="0" y1="-9" x2="0" y2="7" class="gr-s1-flag-pole"></line>
              <polygon points="0,-9 10,-5 0,-1" class="gr-s1-flag-fabric"></polygon>
            </g>

            <g class="gr-s1-msg gr-s1-msg-data1">
              <text y="-15" class="gr-s1-msg-lbl gr-s1-lbl-data">DATA</text>
              <circle cy="0" r="6" class="gr-s1-dot-data"></circle>
            </g>

            <g class="gr-s1-msg gr-s1-msg-dirty2">
              <text y="-16" class="gr-s1-msg-lbl gr-s1-lbl-dirty">DIRTY</text>
              <line x1="0" y1="-9" x2="0" y2="7" class="gr-s1-flag-pole"></line>
              <polygon points="0,-9 10,-5 0,-1" class="gr-s1-flag-fabric"></polygon>
            </g>

            <g class="gr-s1-msg gr-s1-msg-data2">
              <text y="-15" class="gr-s1-msg-lbl gr-s1-lbl-data">DATA</text>
              <circle cy="0" r="6" class="gr-s1-dot-data"></circle>
            </g>

            <g class="gr-s1-msg gr-s1-msg-complete">
              <text y="-13" class="gr-s1-msg-lbl gr-s1-lbl-complete">COMPLETE</text>
              <circle cy="0" r="4" class="gr-s1-dot-slate"></circle>
            </g>
          </g>

          <!-- ═════ STAGE 2 — diamond with full DIRTY/DATA lifecycle (12–17s, 25–35.42%) ═════ -->
          <g class="gr-st gr-st-2">
            <line class="gr-edge gr-s2-edge" x1="0" y1="-120" x2="-158" y2="-14" marker-end="url(#gr-arr)"></line>
            <line class="gr-edge gr-s2-edge" x1="0" y1="-120" x2="158" y2="-14" marker-end="url(#gr-arr)"></line>
            <line class="gr-edge gr-s2-edge" x1="-180" y1="0" x2="-25" y2="103" marker-end="url(#gr-arr)"></line>
            <line class="gr-edge gr-s2-edge" x1="180" y1="0" x2="25" y2="103" marker-end="url(#gr-arr)"></line>
            <!-- A producer → hexagon -->
            <g transform="translate(0 -120)">
              <polygon class="gr-s2-A-shape" points="13,-22 -13,-22 -26,0 -13,22 13,22 26,0"></polygon>
              <text class="gr-nl" y="-38">A</text>
            </g>
            <!-- B / C / D derived → diamonds. B has slow fn, C fast, D joins both. -->
            <g transform="translate(-180 0)">
              <polygon class="gr-s2-B-shape" points="0,-26 26,0 0,26 -26,0"></polygon>
              <text class="gr-nl" y="-38">B · slow fn</text>
            </g>
            <g transform="translate(180 0)">
              <polygon class="gr-s2-C-shape" points="0,-26 26,0 0,26 -26,0"></polygon>
              <text class="gr-nl" y="-38">C · fast fn</text>
            </g>
            <g transform="translate(0 120)">
              <polygon class="gr-s2-D-shape" points="0,-30 30,0 0,30 -30,0"></polygon>
              <text class="gr-nl" y="-46">D · joins B + C</text>
              <text class="gr-s2-fn" y="5">fn(…)</text>
            </g>

            <!-- DIRTY messages (4) — yellow flag glyph with DIRTY label above -->
            <g class="gr-s2-msg gr-s2-d-AB">
              <text y="-15" class="gr-s2-msg-lbl gr-s2-lbl-dirty">DIRTY</text>
              <line x1="0" y1="-9" x2="0" y2="7" class="gr-s2-flag-pole"></line>
              <polygon points="0,-9 10,-5 0,-1" class="gr-s2-flag-fabric"></polygon>
            </g>
            <g class="gr-s2-msg gr-s2-d-AC">
              <text y="-15" class="gr-s2-msg-lbl gr-s2-lbl-dirty">DIRTY</text>
              <line x1="0" y1="-9" x2="0" y2="7" class="gr-s2-flag-pole"></line>
              <polygon points="0,-9 10,-5 0,-1" class="gr-s2-flag-fabric"></polygon>
            </g>
            <g class="gr-s2-msg gr-s2-d-BD">
              <text y="-15" class="gr-s2-msg-lbl gr-s2-lbl-dirty">DIRTY</text>
              <line x1="0" y1="-9" x2="0" y2="7" class="gr-s2-flag-pole"></line>
              <polygon points="0,-9 10,-5 0,-1" class="gr-s2-flag-fabric"></polygon>
            </g>
            <g class="gr-s2-msg gr-s2-d-CD">
              <text y="-15" class="gr-s2-msg-lbl gr-s2-lbl-dirty">DIRTY</text>
              <line x1="0" y1="-9" x2="0" y2="7" class="gr-s2-flag-pole"></line>
              <polygon points="0,-9 10,-5 0,-1" class="gr-s2-flag-fabric"></polygon>
            </g>

            <!-- DATA messages (4) — green dot with DATA label above -->
            <g class="gr-s2-msg gr-s2-D-AB">
              <text y="-15" class="gr-s2-msg-lbl gr-s2-lbl-data">DATA</text>
              <circle cy="0" r="6" class="gr-s2-dot-data"></circle>
            </g>
            <g class="gr-s2-msg gr-s2-D-AC">
              <text y="-15" class="gr-s2-msg-lbl gr-s2-lbl-data">DATA</text>
              <circle cy="0" r="6" class="gr-s2-dot-data"></circle>
            </g>
            <g class="gr-s2-msg gr-s2-D-BD">
              <text y="-15" class="gr-s2-msg-lbl gr-s2-lbl-data">DATA</text>
              <circle cy="0" r="6" class="gr-s2-dot-data"></circle>
            </g>
            <g class="gr-s2-msg gr-s2-D-CD">
              <text y="-15" class="gr-s2-msg-lbl gr-s2-lbl-data">DATA</text>
              <circle cy="0" r="6" class="gr-s2-dot-data"></circle>
            </g>
          </g>

          <!-- ═════ STAGE 3 — node anatomy: smaller rect, larger ports for balance ═════ -->
          <g class="gr-st gr-st-3">
            <!-- The node itself: smaller rounded rect, zooms in -->
            <g class="gr-s3-node-wrap">
              <rect class="gr-s3-node" x="-160" y="-80" width="320" height="160" rx="16"></rect>

              <!-- Concentric rings = fn primitive at the heart (padded so fn(…) text isn't crammed) -->
              <g class="gr-s3-fn-anatomy">
                <circle r="60" class="gr-s3-fn-ring gr-s3-fn-ring-3"></circle>
                <circle r="44" class="gr-s3-fn-ring gr-s3-fn-ring-2"></circle>
                <circle r="28" class="gr-s3-fn-ring gr-s3-fn-ring-1"></circle>
                <text y="5" class="gr-s3-fn-center">fn(…)</text>
              </g>

              <!-- cache (top-center): cylinder icon; inner group shifts so icon+text are visually centered -->
              <g class="gr-s3-tag gr-s3-tag-cache" transform="translate(0 -56)">
                <g transform="translate(-18 0)">
                  <g class="gr-s3-icon">
                    <ellipse cx="0" cy="-4" rx="6" ry="2.2"></ellipse>
                    <path d="M -6 -4 L -6 4 Q 0 6.5 6 4 L 6 -4"></path>
                  </g>
                  <text x="14" y="4" class="gr-s3-tag-text" text-anchor="start">cache</text>
                </g>
              </g>

              <!-- guard (bottom-left): shield icon -->
              <g class="gr-s3-tag gr-s3-tag-guard" transform="translate(-118 58)">
                <g class="gr-s3-icon">
                  <path d="M -7 -6 L 0 -8.5 L 7 -6 Q 7 5 0 8.5 Q -7 5 -7 -6 Z"></path>
                  <path d="M -3 0 L -1 2 L 4 -3" stroke-linecap="round"></path>
                </g>
                <text x="12" y="4" class="gr-s3-tag-text" text-anchor="start">guard</text>
              </g>

              <!-- version (bottom-right): tag icon -->
              <g class="gr-s3-tag gr-s3-tag-ver" transform="translate(78 58)">
                <g class="gr-s3-icon">
                  <path d="M -10 -5 L 2 -5 L 8 0 L 2 5 L -10 5 Z"></path>
                  <circle cx="-6" cy="0" r="1.5" class="gr-s3-icon-dot"></circle>
                </g>
                <text x="18" y="4" class="gr-s3-tag-text gr-s3-ver-text" text-anchor="start">version 3</text>
              </g>
            </g>

            <!-- "↑ UP [deps]" port on the left — linear icon + display word + bracketed annotation -->
            <g class="gr-s3-port gr-s3-port-up" transform="translate(-260 0)">
              <g class="gr-s3-port-head" transform="translate(0 -22)">
                <polyline class="gr-s3-port-icon" points="-44,4 -38,-4 -32,4"></polyline>
                <text x="-24" y="5" class="gr-s3-port-primary">UP</text>
                <text x="6" y="4" class="gr-s3-port-secondary">[deps]</text>
              </g>
              <line x1="80" y1="0" x2="-12" y2="0" class="gr-s3-port-line" marker-end="url(#gr-arr-port)"></line>
            </g>

            <!-- "↓ DOWN [subs]" port on the right -->
            <g class="gr-s3-port gr-s3-port-down" transform="translate(260 0)">
              <g class="gr-s3-port-head" transform="translate(0 -22)">
                <polyline class="gr-s3-port-icon" points="-54,-4 -48,4 -42,-4"></polyline>
                <text x="-34" y="5" class="gr-s3-port-primary">DOWN</text>
                <text x="12" y="4" class="gr-s3-port-secondary">[subs]</text>
              </g>
              <line x1="-80" y1="0" x2="12" y2="0" class="gr-s3-port-line" marker-end="url(#gr-arr-port)"></line>
            </g>
          </g>

          <!-- ═════ STAGE 4 — four sugars (Y-shape) ═════ -->
          <g class="gr-st gr-st-4">
            <g class="gr-s4-morph">
              <!-- state → square -->
              <rect class="gr-s4-m gr-s4-m-state" x="-40" y="-40" width="80" height="80" rx="2"></rect>
              <!-- producer → hexagon -->
              <polygon class="gr-s4-m gr-s4-m-producer" points="20,-35 -20,-35 -40,0 -20,35 20,35 40,0"></polygon>
              <!-- derived → diamond -->
              <polygon class="gr-s4-m gr-s4-m-derived" points="0,-40 40,0 0,40 -40,0"></polygon>
              <!-- effect → parallelogram -->
              <polygon class="gr-s4-m gr-s4-m-effect" points="-22,-24 50,-24 36,24 -36,24"></polygon>
              <text class="gr-s4-mlabel gr-s4-ml-state" y="6">state</text>
              <text class="gr-s4-mlabel gr-s4-ml-producer" y="6">producer</text>
              <text class="gr-s4-mlabel gr-s4-ml-derived" y="6">derived</text>
              <text class="gr-s4-mlabel gr-s4-ml-effect" y="6">effect</text>
            </g>
            <g class="gr-s4-y">
              <line class="gr-edge gr-s4-eSD" x1="-220" y1="-80" x2="-32" y2="-12" marker-end="url(#gr-arr)"></line>
              <line class="gr-edge gr-s4-ePD" x1="-220" y1="80" x2="-32" y2="12" marker-end="url(#gr-arr)"></line>
              <line class="gr-edge gr-s4-eDE" x1="40" y1="0" x2="188" y2="0" marker-end="url(#gr-arr)"></line>
              <!-- state → square -->
              <g transform="translate(-220 -80)">
                <rect class="gr-s4-n-state" x="-22" y="-22" width="44" height="44" rx="2"></rect>
                <text class="gr-nl" y="-32">state</text>
              </g>
              <!-- producer → hexagon -->
              <g transform="translate(-220 80)">
                <polygon class="gr-s4-n-producer" points="11,-19 -11,-19 -22,0 -11,19 11,19 22,0"></polygon>
                <text class="gr-nl" y="-34">producer</text>
              </g>
              <!-- derived → diamond -->
              <g transform="translate(0 0)">
                <polygon class="gr-s4-n-derived" points="0,-32 32,0 0,32 -32,0"></polygon>
                <text class="gr-nl" y="-44">derived</text>
                <text class="gr-s4-y-fn" y="5">fn(…)</text>
              </g>
              <!-- effect → parallelogram -->
              <g transform="translate(220 0)">
                <polygon class="gr-s4-n-effect" points="-18,-18 38,-18 28,18 -28,18"></polygon>
                <text class="gr-nl" y="-30">effect</text>
              </g>
              <circle class="gr-s4-msg gr-s4-d-SD" r="5"></circle>
              <circle class="gr-s4-msg gr-s4-d-PD" r="5"></circle>
              <circle class="gr-s4-msg gr-s4-D-SD" r="6"></circle>
              <circle class="gr-s4-msg gr-s4-D-PD" r="6"></circle>
              <circle class="gr-s4-msg gr-s4-D-DE" r="6"></circle>
            </g>
          </g>

          <!-- ═════ STAGE 5 — graph level (mesh · blueprint+lens · batch · capsules) ═════ -->
          <g class="gr-st gr-st-5">
            <g class="gr-s5-mesh">
              <line class="gr-edge gr-s5-edge" x1="-280" y1="-110" x2="-130" y2="-60"></line>
              <line class="gr-edge gr-s5-edge" x1="-280" y1="-110" x2="-200" y2="40"></line>
              <line class="gr-edge gr-s5-edge" x1="-130" y1="-60" x2="0" y2="-110"></line>
              <line class="gr-edge gr-s5-edge" x1="-130" y1="-60" x2="-50" y2="60"></line>
              <line class="gr-edge gr-s5-edge" x1="-200" y1="40" x2="-50" y2="60"></line>
              <line class="gr-edge gr-s5-edge" x1="-50" y1="60" x2="80" y2="110"></line>
              <line class="gr-edge gr-s5-edge" x1="0" y1="-110" x2="160" y2="-70"></line>
              <line class="gr-edge gr-s5-edge" x1="160" y1="-70" x2="280" y2="-10"></line>
              <line class="gr-edge gr-s5-edge" x1="80" y1="110" x2="240" y2="90"></line>
              <line class="gr-edge gr-s5-edge" x1="280" y1="-10" x2="240" y2="90"></line>
              <line class="gr-edge gr-s5-edge" x1="0" y1="-110" x2="80" y2="110"></line>
              <line class="gr-edge gr-s5-edge" x1="-50" y1="60" x2="160" y2="-70"></line>

              <circle class="gr-s5-n" cx="-280" cy="-110" r="11"></circle>
              <circle class="gr-s5-n" cx="-130" cy="-60" r="11"></circle>
              <circle class="gr-s5-n" cx="-200" cy="40" r="11"></circle>
              <circle class="gr-s5-n" cx="0" cy="-110" r="11"></circle>
              <circle class="gr-s5-n" cx="-50" cy="60" r="11"></circle>
              <circle class="gr-s5-n" cx="160" cy="-70" r="11"></circle>
              <circle class="gr-s5-n" cx="80" cy="110" r="11"></circle>
              <circle class="gr-s5-n" cx="280" cy="-10" r="11"></circle>
              <circle class="gr-s5-n" cx="240" cy="90" r="11"></circle>
            </g>

            <g class="gr-s5-lens">
              <circle class="gr-s5-lens-glass" r="76" fill="url(#gr-lensGrad)"></circle>
              <circle class="gr-s5-lens-ring" r="76"></circle>
              <line class="gr-s5-lens-stem" x1="54" y1="54" x2="80" y2="80"></line>
            </g>

            <path class="gr-s5-bracket gr-s5-bracket-l" d="M -360 -150 L -390 -150 L -390 150 L -360 150"></path>
            <path class="gr-s5-bracket gr-s5-bracket-r" d="M 360 -150 L 390 -150 L 390 150 L 360 150"></path>

            <ellipse class="gr-s5-cap gr-s5-cap-a" cx="-150" cy="-30" rx="200" ry="120"></ellipse>
            <ellipse class="gr-s5-cap gr-s5-cap-b" cx="180" cy="30" rx="180" ry="110"></ellipse>

            <text class="gr-s5-lbl gr-s5-lbl-describe" x="0" y="-138">graph.describe() — the map</text>
            <text class="gr-s5-lbl gr-s5-lbl-observe" x="0" y="148">graph.observe() — the magnifier</text>
            <text class="gr-s5-lbl gr-s5-lbl-batch" x="0" y="-138">batch() — defers DATA, not DIRTY</text>
            <text class="gr-s5-lbl gr-s5-lbl-cap" x="0" y="148">subgraphs · multi-agent ownership</text>
          </g>

          <!-- ═════ STAGE 6 — orchestrate + messaging ═════ -->
          <g class="gr-st gr-st-6">
            <ellipse class="gr-s6-cap gr-s6-cap-l" cx="-220" cy="0" rx="180" ry="80"></ellipse>
            <!-- Pipeline edges between rounded-rect nodes (rect half-width = 22) -->
            <line class="gr-edge gr-s6-pipe-edge" x1="-318" y1="0" x2="-282" y2="0" marker-end="url(#gr-arr)"></line>
