.gr-s1-dn-label { animation: gr-s1-dn-label 48s infinite linear; }
@keyframes gr-s1-dn-label {
  0%, 6% { fill: rgba(148,163,184,0.4); }
  7%, 20% { fill: rgba(244,247,249,0.7); }
  21%, 100% { fill: rgba(148,163,184,0.4); }
}

