  7%, 9.3% { fill: rgba(96,165,250,0.22); stroke: #60A5FA; }                  /* clean (after START) */
  9.5%, 11.3% { fill: url(#gr-dirty); stroke: #FBBF24; }                       /* DIRTY1 received */
  11.5%, 12.3% { fill: rgba(52,211,153,0.32); stroke: #34D399; }              /* fn1 running (DATA1 arrived) */
  12.5%, 13.8% { fill: rgba(96,165,250,0.22); stroke: #60A5FA; }              /* clean after fn1 */
  14%, 16.3% { fill: url(#gr-dirty); stroke: #FBBF24; }                        /* DIRTY2 received */
  16.5%, 17.3% { fill: rgba(52,211,153,0.32); stroke: #34D399; }              /* fn2 running */
  17.5%, 19.8% { fill: rgba(96,165,250,0.22); stroke: #60A5FA; }              /* clean after fn2 */
  21%, 100% { fill: rgba(148,163,184,0.08); stroke: rgba(148,163,184,0.32); } /* gray (COMPLETE) */
