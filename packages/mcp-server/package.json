{
	"name": "@graphrefly/mcp-server",
	"version": "0.0.1",
	"description": "Model Context Protocol server for GraphReFly — expose graph operations (create, describe, observe, explain, reduce, snapshot) as MCP tools.",
	"license": "MIT",
	"mcpName": "io.github.graphrefly/mcp-server",
	"repository": {
		"type": "git",
		"url": "https://github.com/graphrefly/graphrefly-ts",
		"directory": "packages/mcp-server"
	},
	"bugs": {
		"url": "https://github.com/graphrefly/graphrefly-ts/issues"
	},
	"homepage": "https://graphrefly.dev",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"graphrefly-mcp": "dist/bin.js"
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"test": "vitest run",
		"lint": "biome check .",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"prepublishOnly": "pnpm build && pnpm test"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@graphrefly/graphrefly": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.0.0",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"graphrefly",
		"reactive-graph",
		"agent-harness",
		"llm-tools"
	]
}
