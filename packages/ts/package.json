{
	"name": "@graphrefly/ts",
	"version": "0.0.0",
	"description": "GraphReFly clean-slate TypeScript substrate — node / dispatcher / pool / wave protocol.",
	"type": "module",
	"sideEffects": false,
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": ["dist", "LICENSE"],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"license": "MIT",
	"devDependencies": {
		"tsup": "^8.5.1",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
